@using webMetics.Controllers

<!--
    Vista para mostrar la lista de todos los asesores con la información personal de cada uno
    Se muestran las opciones de poder eliminar, editar o crear un asesor
-->

@{
    ViewBag.Title = "Facilitadores(as)";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
}

@if (ViewBag.Id != "" && ViewBag.Role == 1)
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" href="@Url.Action("ListaGruposDisponibles", "Grupo")">
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>
        }

        <h1>@ViewBag.Title</h1>
        <hr />

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-dark alert-dismissible fade show mb-4" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @ViewBag.SuccessMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive">
            @if (ViewBag.Asesores == null)
            {
                <h5 class="text-center">No hay facilitadores(as).</h5>
            }
            else
            {
                <div class="table-card">
                    <div class="table-card-header">
                        <span class="table-card-title">Facilitadores(as)</span>
                        <span class="table-card-desc">Listado de facilitadores(as) registrados en el sistema</span>
                    </div>

                    <div class="table-toolbar">
                        <div class="table-toolbar-group">
                            <div class="table-pagesize">
                                <label for="asesorPageSize">Mostrar</label>
                                <select id="asesorPageSize">
                                    <option selected>5</option>
                                    <option>10</option>
                                    <option>25</option>
                                    <option>50</option>
                                </select>
                                <label for="asesorPageSize">registros</label>
                            </div>

                            <form asp-action="BuscarAsesores" asp-controller="Asesor" method="get" class="table-search">
                                <input type="text" name="searchTerm" class="form-control" placeholder="Buscar facilitador(a)" value="@Context.Request.Query["searchTerm"]" />
                                <button class="btn" type="submit"><i class="bi bi-search"></i></button>
                            </form>
                        </div>

                        <div>
                            @Html.ActionLink("  Crear Facilitador(a)", "CrearAsesor", "Asesor", new { }, new { @class = "btn btn-primary bi bi-plus-lg btn-table-sm" })
                        </div>
                    </div>

                    <div class="table-scroll">
                        <table id="asesorTblCustomers" class="data-table" style="min-width: 900px;">
                            <thead>
                                <tr>
                                    <th scope="col" style="width: 11%;">Nombre</th>
                                    <th scope="col" style="width: 9%;">Primer Apellido</th>
                                    <th scope="col" style="width: 9%;">Segundo Apellido</th>
                                    <th scope="col" style="width: 13%;">Correo Institucional</th>
                                    <th scope="col" style="width: 15%;">Descripción</th>
                                    <th scope="col" style="width: 6%;">Teléfono</th>
                                    <th scope="col" class="text-center" style="width: 4%;">Editar</th>
                                    <th scope="col" class="text-center" style="width: 4%;">Eliminar</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var asesor in ViewBag.Asesores)
                                {
                                    var nombreCompleto = asesor.nombre;
                                    nombreCompleto += " " + asesor.primerApellido;
                                    if (asesor.segundoApellido != "-")
                                    {
                                        nombreCompleto += " " + asesor.segundoApellido;
                                    }

                                    <tr>
                                        <td>@asesor.nombre</td>
                                        <td>@asesor.primerApellido</td>
                                        <td>@asesor.segundoApellido</td>
                                        <td>@asesor.correo</td>
                                        <td>@asesor.descripcion</td>
                                        <td>@asesor.telefono</td>
                                        <td class="text-center">
                                            <a href="@Url.Action("EditarAsesor", "Asesor", new { idAsesor = asesor.idAsesor })" class="icon-action icon-edit" title="Editar">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                        </td>
                                        <td class="text-center">
                                            <a href="#" onclick="openAsesorDeleteModal('@asesor.idAsesor'); return false;" class="icon-action icon-delete" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div id="asesorTblPaginacion" class="table-pagination"></div>
                </div>
            }
        </div>
    </div>

    <div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Eliminar facilitador(a)</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro de que desea eliminar a este(a) facilitador(a)?

                    @using (Html.BeginForm("EliminarAsesor", "Asesor"))
                    {
                        @Html.AntiForgeryToken()

                        <div class="modal-footer">
                            <input type="hidden" id="idAsesor" name="idAsesor">
                            <input type="submit" class="btn btn-danger" value="Aceptar" />
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}

<script type="text/javascript">
    // Función para abrir modal de eliminación
    function openAsesorDeleteModal(asesorId) {
        document.getElementById("idAsesor").value = asesorId;
        var deleteModal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        deleteModal.show();
    }

    // Función heredada para mantener compatibilidad
    function actualizarModalEliminar(idAsesor) {
        openAsesorDeleteModal(idAsesor);
    }

    MeticsTable.init({
        tableId: 'asesorTblCustomers',
        pageSizeId: 'asesorPageSize',
        paginationId: 'asesorTblPaginacion',
        searching: false
    });
</script>
