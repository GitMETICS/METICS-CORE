@using webMetics.Controllers
@{
    ViewBag.Title = "Áreas de Competencia";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
}

@if (ViewBag.Id != "" && ViewBag.Role == 1)
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" href="@Url.Action("ListaGruposDisponibles", "Grupo")">
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>
        }

        <h1>@ViewBag.Title</h1>
        <hr />

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-dark alert-dismissible fade show mb-4" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @ViewBag.SuccessMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (ViewBag.Temas == null)
        {
            <h5 class="text-center mb-4">No hay temas.</h5>
            <div class="text-center">
                @Html.ActionLink("  Crear Área de Competencia", "CrearTema", "Tema", new { }, new { @class = "btn btn-primary bi bi-plus-lg" })
            </div>
        }
        else
        {
            <div class="table-card">
                <div class="table-card-header">
                    <span class="table-card-title">Áreas de Competencia</span>
                    <span class="table-card-desc">Listado de áreas de competencia registradas en el sistema</span>
                </div>

                <div class="table-toolbar">
                    <div class="table-toolbar-group">
                        <div class="table-pagesize">
                            <label for="temaPageSize">Mostrar</label>
                            <select id="temaPageSize">
                                <option>5</option>
                                <option>10</option>
                                <option>25</option>
                                <option selected>50</option>
                            </select>
                            <label for="temaPageSize">registros</label>
                        </div>

                        <div class="table-search">
                            <input type="text" id="temaBusqueda" class="form-control" placeholder="Buscar área de competencia" />
                            <button type="button" class="btn"><i class="bi bi-search"></i></button>
                        </div>
                    </div>

                    <div>
                        @Html.ActionLink("  Crear Área", "CrearTema", "Tema", new { }, new { @class = "btn btn-primary bi bi-plus-lg btn-table-sm" })
                    </div>
                </div>

                <div class="table-scroll">
                    <table id="temaTblCustomers" class="data-table" style="min-width: 600px;">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 85%;">Nombre</th>
                                <th scope="col" class="text-center" style="width: 7.5%;">Editar</th>
                                <th scope="col" class="text-center" style="width: 7.5%;">Eliminar</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var tema in ViewBag.Temas)
                            {
                                <tr>
                                    <td>@tema.nombre</td>
                                    <td class="text-center">
                                        @Html.ActionLink("", "EditarTema", "Tema", new { idTema = tema.idTema }, new { @class = "icon-action icon-edit bi bi-pencil-square", @title = "Editar" })
                                    </td>
                                    <td class="text-center">
                                        <a href="#" onclick="actualizarModalEliminar('@tema.idTema'); return false;" class="icon-action icon-delete bi bi-trash" title="Eliminar"></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div id="temaTblPaginacion" class="table-pagination"></div>
            </div>
        }
    </div>

    <div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Eliminar Área de competencia</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro de que desea eliminar esta área de competencia?
                    <br />
                    @using (Html.BeginForm("EliminarTema", "Tema"))
                    {
                        <div class="modal-footer">
                            <input type="hidden" id="idTema" name="idTema">
                            <input type="submit" class="btn btn-danger" value="Aceptar" />
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}

<script type="text/javascript">
    function actualizarModalEliminar(idTema) {
        document.getElementById("idTema").value = idTema;
        var deleteModal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        deleteModal.show();
    }

    MeticsTable.init({
        tableId: 'temaTblCustomers',
        pageSizeId: 'temaPageSize',
        paginationId: 'temaTblPaginacion',
        searching: true,
        searchInputId: 'temaBusqueda',
        pageLength: 50
    });
</script>
