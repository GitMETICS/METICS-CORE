@using webMetics.Controllers
@{
    ViewBag.Title = "Áreas de Competencia";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
}

<style>
    /* Estilos para la tabla de temas - Diseño Moderno */
    .tema-table-card {
        background: white;
        border: 2px solid #41ADE7;
        border-radius: 4px;
        margin-top: 20px;
        overflow: hidden;
        max-width: 100%;
    }

    .tema-table-header {
        background: #E3F3FB;
        border-bottom: 1px solid #CCCCCC;
        padding: 11px 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    #temaTblWrapper {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 70vh;
        width: 100%;
        background: white;
    }

    #temaTblCustomers {
        min-width: 600px;
    }

    #temaTblPaginacion {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 4px;
        padding: 13px;
        border-top: 1px solid #ECECEC;
        background: white;
    }

    /* Estilos para iconos de acciones */
    .tema-icon-editar {
        color: #0090D8;
        text-decoration: none;
        font-size: 14px;
        cursor: pointer;
        transition: opacity 0.2s ease, transform 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .tema-icon-editar:hover {
        opacity: 0.8;
        transform: scale(1.1);
    }

    .tema-icon-eliminar {
        color: #C0392B;
        text-decoration: none;
        font-size: 14px;
        cursor: pointer;
        transition: opacity 0.2s ease, transform 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .tema-icon-eliminar:hover {
        opacity: 0.8;
        transform: scale(1.1);
    }
</style>

@if (ViewBag.Id != "" && ViewBag.Role == 1)
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" href="@Url.Action("ListaGruposDisponibles", "Grupo")">
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>
        }

        <h1>@ViewBag.Title</h1>
        <hr />

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-dark alert-dismissible fade show mb-4" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @ViewBag.SuccessMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (ViewBag.Temas == null)
        {
            <h5 class="text-center mb-4">No hay temas.</h5>
            <div class="text-center">
                @Html.ActionLink("  Crear Área de Competencia", "CrearTema", "Tema", new { }, new { @class = "btn btn-primary bi bi-plus-lg" })
            </div>
        }
        else
        {
            <div class="tema-table-card">
                <!-- Encabezado de tarjeta -->
                <div class="tema-table-header">
                    <span style="font-weight: bold; font-size: 14px; color: #204C6F;">Áreas de Competencia</span>
                    <span style="font-size: 12px; color: #555;">Listado de áreas de competencia registradas en el sistema</span>
                </div>

                <!-- Controles: Mostrar registros, búsqueda y crear -->
                <div style="padding: 14px 14px 10px 14px; background: white; border-bottom: 1px solid #ECECEC; display: flex; align-items: center; gap: 15px; flex-wrap: wrap; justify-content: space-between;">
                    <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                        <div style="display: flex; align-items: center; gap: 6px;">
                            <label for="temaPageSize" style="font-size: 12px; color: #333; white-space: nowrap;">Mostrar</label>
                            <select id="temaPageSize" style="padding: 4px 6px; border: 1px solid #BFBFBF; background: white; font-size: 12px; border-radius: 2px;">
                                <option selected>5</option>
                                <option>10</option>
                                <option>25</option>
                                <option>50</option>
                            </select>
                            <label for="temaPageSize" style="font-size: 12px; color: #333; white-space: nowrap;">registros</label>
                        </div>

                        <div style="flex: 1; min-width: 200px; display: flex; gap: 5px;">
                            <input type="text" id="temaBusqueda" class="form-control" placeholder="Buscar área de competencia" style="font-size: 12px; padding: 4px 8px; border: 1px solid #BFBFBF; border-radius: 2px; flex: 1; min-width: 0;" />
                            <button onclick="buscarTema()" class="btn btn-sm" style="background: white; border: 1px solid #BFBFBF; color: #333; font-size: 12px; padding: 4px 10px; border-radius: 2px; flex-shrink: 0;">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>

                    <div style="flex-shrink: 0;">
                        @Html.ActionLink("  Crear Área", "CrearTema", "Tema", new { }, new { @class = "btn btn-primary bi bi-plus-lg", style = "font-size: 12px; padding: 4px 12px;" })
                    </div>
                </div>

                <!-- Tabla con scroll responsivo -->
                <div id="temaTblWrapper">
                    <table id="temaTblCustomers" style="border-collapse: collapse; font-size: 12px; width: 100%; background: white; margin: 0;">
                        <thead>
                            <tr>
                                <th scope="col" style="background: #ECECEC; border: 1px solid #CCCCCC; padding: 9px 9px; font-weight: bold; white-space: nowrap; color: #333; text-align: left; width: 85%;">Nombre</th>
                                <th scope="col" style="background: #ECECEC; border: 1px solid #CCCCCC; padding: 9px 9px; font-weight: bold; white-space: nowrap; color: #333; text-align: center; width: 7.5%;">Editar</th>
                                <th scope="col" style="background: #ECECEC; border: 1px solid #CCCCCC; padding: 9px 9px; font-weight: bold; white-space: nowrap; color: #333; text-align: center; width: 7.5%;">Eliminar</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var tema in ViewBag.Temas)
                            {
                                <tr style="background: white;">
                                    <td style="border: 1px solid #CCCCCC; padding: 8px 9px; vertical-align: middle;">@tema.nombre</td>
                                    <td style="border: 1px solid #CCCCCC; padding: 8px 9px; vertical-align: middle; text-align: center;">
                                        @Html.ActionLink("", "EditarTema", "Tema", new { idTema = tema.idTema }, new { @class = "tema-icon-editar bi bi-pencil-square", @title = "Editar" })
                                    </td>
                                    <td style="border: 1px solid #CCCCCC; padding: 8px 9px; vertical-align: middle; text-align: center;">
                                        <a href="#" onclick="actualizarModalEliminar('@tema.idTema'); return false;" class="tema-icon-eliminar bi bi-trash" title="Eliminar">
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Paginación FUERA del scroll (fija) -->
                <div id="temaTblPaginacion"></div>
            </div>
        }
    </div>

    <div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Eliminar Área de competencia</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro de que desea eliminar esta área de competencia?
                    <br />
                    @using (Html.BeginForm("EliminarTema", "Tema"))
                    {
                        <div class="modal-footer">
                            <input type="hidden" id="idTema" name="idTema">
                            <input type="submit" class="btn btn-danger" value="Aceptar" />
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}

<script type="text/javascript">
    function actualizarModalEliminar(idTema) {
        document.getElementById("idTema").value = idTema;
        var deleteModal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        deleteModal.show();
    }

    function buscarTema() {
        var searchInput = document.getElementById('temaBusqueda');
        if (!searchInput || !temaTable) return;

        temaTable.search(searchInput.value.trim()).draw();
    }

    // Permitir búsqueda al presionar Enter
    document.addEventListener('DOMContentLoaded', function() {
        var busquedaInput = document.getElementById('temaBusqueda');
        if (busquedaInput) {
            busquedaInput.addEventListener('keypress', function(event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    buscarTema();
                }
            });

            // También permitir búsqueda mientras se escribe
            busquedaInput.addEventListener('input', function() {
                buscarTema();
            });
        }
    });
</script>

<link rel="stylesheet" href="https://cdn.datatables.net/1.12.1/css/jquery.dataTables.min.css">
<script src="https://code.jquery.com/jquery-3.5.1.js"></script>
<script src="https://cdn.datatables.net/1.12.1/js/jquery.dataTables.min.js"></script>

<script>
    var temaTableElement = document.getElementById('temaTblCustomers');
    var temaTablePageSize = document.getElementById('temaPageSize');
    var temaTablePagination = document.getElementById('temaTblPaginacion');
    var temaTable;

    if (temaTableElement) {
        temaTable = new DataTable('#temaTblCustomers', {
            language: {
                url: '//cdn.datatables.net/plug-ins/2.1.7/i18n/es-ES.json',
            },
            searching: true,
            paging: true,
            pageLength: 5,
            lengthMenu: [5, 10, 25, 50],
            info: false,
            lengthChange: false,
            dom: 't',
            pagingType: "simple_numbers",
            drawCallback: function () {
                if (!window.bootstrap?.Tooltip) return;
                $(this.api().rows({ page: 'current' }).nodes()).find('[data-bs-toggle="tooltip"]').each(function () {
                    var existing = bootstrap.Tooltip.getInstance(this);
                    if (!existing) {
                        new bootstrap.Tooltip(this);
                    }
                });
            }
        });

        function renderTemaPagination() {
            if (!temaTablePagination) return;

            var paginationHtml = '';
            var pageInfo = temaTable.page.info();
            var pageCount = Math.ceil(pageInfo.recordsDisplay / pageInfo.length);
            var currentPage = pageInfo.page + 1;

            if (pageCount <= 1) {
                temaTablePagination.innerHTML = '';
                return;
            }

            if (currentPage > 1) {
                paginationHtml += '<a href="#" class="paginate_button" onclick="temaTable.page(' + (currentPage - 2) + ').draw(false); return false;" style="background: white; border: 1px solid #CCCCCC; padding: 5px 12px; font-size: 12px; cursor: pointer; color: #333; font-family: Arial; border-radius: 2px; margin: 0 2px; display: inline-block; text-decoration: none;">&laquo;</a>';
            }

            for (var i = 1; i <= pageCount; i++) {
                if (i === currentPage) {
                    paginationHtml += '<span class="paginate_button current" style="background: #204C6F; color: white; border: 1px solid #204C6F; padding: 5px 12px; font-size: 12px; font-family: Arial; border-radius: 2px; margin: 0 2px; display: inline-block;">' + i + '</span>';
                } else {
                    paginationHtml += '<a href="#" class="paginate_button" onclick="temaTable.page(' + (i - 1) + ').draw(false); return false;" style="background: white; border: 1px solid #CCCCCC; padding: 5px 12px; font-size: 12px; cursor: pointer; color: #333; font-family: Arial; border-radius: 2px; margin: 0 2px; display: inline-block; text-decoration: none;">' + i + '</a>';
                }
            }

            if (currentPage < pageCount) {
                paginationHtml += '<a href="#" class="paginate_button" onclick="temaTable.page(' + currentPage + ').draw(false); return false;" style="background: white; border: 1px solid #CCCCCC; padding: 5px 12px; font-size: 12px; cursor: pointer; color: #333; font-family: Arial; border-radius: 2px; margin: 0 2px; display: inline-block; text-decoration: none;">&raquo;</a>';
            }

            temaTablePagination.innerHTML = paginationHtml;
        }

        temaTable.on('draw', renderTemaPagination);
        renderTemaPagination();

        if (temaTablePageSize) {
            temaTablePageSize.addEventListener('change', function() {
                var value = parseInt(this.value);
                temaTable.page.len(value).draw();
            });
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        if (!temaTableElement || !window.bootstrap?.Tooltip) return;
        $('#temaTblCustomers [data-bs-toggle="tooltip"]').each(function () {
            if (!bootstrap.Tooltip.getInstance(this)) {
                new bootstrap.Tooltip(this);
            }
        });
    });
</script>
