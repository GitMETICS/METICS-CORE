@model webMetics.Models.ParticipanteModel
@using webMetics.Controllers
@using webMetics.Helpers
@{
    ViewBag.Title = "Formulario de Participante";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
    var areasDisponibles = (ViewData["jsonDataAreas"] as List<string> ?? new List<string>())
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(a => a)
        .ToList();
}

@if (ViewBag.Title == "Formulario de Participante")
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" onclick="history.go(-1); return false;" href="#">
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>
        }

        @using (Html.BeginForm("FormularioParticipante", "Participante", FormMethod.Post, new { enctype = "multipart/form-data", id = "participanteCreateForm" }))
        {
            @Html.AntiForgeryToken()
            <h1>@ViewBag.Title</h1>
            <hr />

            if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-dark alert-dismissible fade show mx-2" role="alert">
                    <span>@ViewBag.ErrorMessage</span>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            if (ViewBag.SuccessMessage != null)
            {
                <div class="alert alert-success alert-dismissible fade show mx-2" role="alert">
                    <span>@ViewBag.SuccessMessage</span>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="row mb-1">
                <div class="col">
                    <div class="container">
                        <div class="form-group">
                            @Html.LabelFor(participanteModel => participanteModel.nombre, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                            @Html.TextBoxFor(participanteModel => participanteModel.nombre, new { @class = "form-control", @maxlength = "64", @autocomplete = "off" })
                            @Html.ValidationMessageFor(participanteModel => participanteModel.nombre, "", new { @class = "text-danger" })
                        </div>
                        <div class="row mt-1">
                            <div class="col">
                                @Html.LabelFor(participanteModel => participanteModel.primerApellido, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                                @Html.TextBoxFor(participanteModel => participanteModel.primerApellido, new { @class = "form-control", @maxlength = "64", @autocomplete = "off" })
                                @Html.ValidationMessageFor(participanteModel => participanteModel.primerApellido, "", new { @class = "text-danger" })
                            </div>
                            <div class="col">
                                @Html.LabelFor(participanteModel => participanteModel.segundoApellido, new { Style = "font-size:22px" })
                                @Html.TextBoxFor(participanteModel => participanteModel.segundoApellido, new { @class = "form-control", @maxlength = "64", @autocomplete = "off" })
                                @Html.ValidationMessageFor(participanteModel => participanteModel.segundoApellido, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="row mt-1">
                            <div class="col">
                                @Html.LabelFor(participanteModel => participanteModel.correo, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                                @Html.TextBoxFor(participanteModel => participanteModel.correo, new { @class = "form-control", @maxlength = "64", @autocomplete = "off" })
                                @Html.ValidationMessageFor(participanteModel => participanteModel.correo, "", new { @class = "text-danger" })
                            </div>
                            <div class="col">
                                @Html.LabelFor(participanteModel => participanteModel.correoAlternativo, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                                @Html.TextBoxFor(participanteModel => participanteModel.correoAlternativo, new { @class = "form-control", @maxlength = "64", @autocomplete = "off", @type = "email" })
                                @Html.ValidationMessageFor(participanteModel => participanteModel.correoAlternativo, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="row mt-1">
                            <div class="col">
                                @Html.LabelFor(participanteModel => participanteModel.tipoIdentificacion, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                                @Html.DropDownListFor(participanteModel => participanteModel.tipoIdentificacion, new SelectList(Enum.GetValues(typeof(webMetics.Models.TipoIdentificacion))), "Seleccione su tipo de identificación...", new { @class = "form-control" })
                                @Html.ValidationMessageFor(participanteModel => participanteModel.tipoIdentificacion, "", new { @class = "text-danger" })
                            </div>
                            <div class="col">
                                @Html.LabelFor(usuarioModel => usuarioModel.numeroIdentificacion, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                                @Html.TextBoxFor(usuarioModel => usuarioModel.numeroIdentificacion, new { @class = "form-control", @maxlength = "64", @autocomplete = "off" })
                                @Html.ValidationMessageFor(usuarioModel => usuarioModel.numeroIdentificacion, "", new { @class = "text-danger" })
                                <small class="form-text text-muted">
                                    Formato de cédula: 1-1100-1100 (con guiones)
                                </small>
                            </div>
                        </div>
                        <div class="form-group mt-1">
                            @Html.LabelFor(participanteModel => participanteModel.tipoParticipante, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                            @Html.DropDownListFor(
                                     usuarioModel => usuarioModel.tipoParticipante,
                                     new SelectList(
                                     Enum.GetValues(typeof(webMetics.Models.TipoDeParticipantes))
                                     .Cast<webMetics.Models.TipoDeParticipantes>()
                                     .Select(e => new { Value = e, Text = EnumHelper.GetDisplayName(e) }),
                                     "Value",
                                     "Text"),
                                     "Seleccione un tipo de participante...",
                                     new { @class = "form-control" })
                            @Html.ValidationMessageFor(participanteModel => participanteModel.tipoParticipante, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group mt-1">
                            @Html.LabelFor(participanteModel => participanteModel.area, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                            @Html.DropDownListFor(participanteModel => participanteModel.area, new SelectList(ViewData["jsonDataAreas"] as List<string>), "Seleccione un área...", new { @class = "form-control", id = "areaDropdown" })
                            @Html.ValidationMessageFor(participanteModel => participanteModel.area, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group mt-1">
                            @Html.LabelFor(participanteModel => participanteModel.departamento, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                            @Html.DropDownListFor(participanteModel => participanteModel.departamento, new SelectList(Enumerable.Empty<SelectListItem>()), "Seleccione un departamento...", new { @class = "form-control", id = "departamentoDropdown" })
                            @Html.ValidationMessageFor(participanteModel => participanteModel.departamento, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group mt-1">
                            @Html.LabelFor(participanteModel => participanteModel.unidadAcademica, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                            @Html.DropDownListFor(participanteModel => participanteModel.unidadAcademica, new SelectList(Enumerable.Empty<SelectListItem>()), "Seleccione una unidad académica...", new { @class = "form-control", id = "seccionDropdown" })
                            @Html.ValidationMessageFor(participanteModel => participanteModel.unidadAcademica, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group mt-1">
                            @Html.LabelFor(participanteModel => participanteModel.sede, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                    @Html.DropDownListFor(participanteModel => participanteModel.sede, webMetics.Controllers.ParticipanteController.GetSedes(), "Seleccione una sede y recinto...", new { @class = "form-control", id = "sedeDropdown" })
                            @Html.ValidationMessageFor(participanteModel => participanteModel.sede, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group mt-1">
                            @Html.LabelFor(participanteModel => participanteModel.telefono, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                            @Html.TextBoxFor(participanteModel => participanteModel.telefono, new { @class = "form-control", @maxlength = "64", @minlength = "7", @autocomplete = "off" })
                            @Html.ValidationMessageFor(participanteModel => participanteModel.telefono, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group mt-1">
                            @Html.LabelFor(participanteModel => participanteModel.carrera, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a>
                            @Html.DropDownListFor(participanteModel => participanteModel.carrera, new SelectList(Enumerable.Empty<SelectListItem>()), "Seleccione una carrera...", new { @class = "form-control", id = "carreraDropdown" })
                            @Html.ValidationMessageFor(participanteModel => participanteModel.carrera, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group mt-1">
                            <fieldset class="border rounded p-3">
                                <legend class="float-none w-auto px-2" style="font-size:22px">Áreas extra</legend>
                                <small class="form-text text-muted d-block mb-2">
                                    Opcional. Debe ser diferente al área principal.
                                </small>

                                @{ int areaIndex = 0; }
                                @foreach (var areaExtra in areasDisponibles)
                                {
                                    var checkboxId = $"areaExtra_{areaIndex++}";
                                    <div class="form-check">
                                        <input
                                            class="form-check-input area-extra-checkbox"
                                            type="checkbox"
                                            name="areasExtra"
                                            id="@checkboxId"
                                            value="@areaExtra"
                                            @(Model?.areasExtra?.Contains(areaExtra, StringComparer.OrdinalIgnoreCase) == true ? "checked" : null) />
                                        <label class="form-check-label" for="@checkboxId">@areaExtra</label>
                                    </div>
                                }

                                @Html.ValidationMessageFor(participanteModel => participanteModel.areasExtra, "", new { @class = "text-danger" })
                            </fieldset>
                        </div>
                        <div class="form-group mt-1">
                            @Html.LabelFor(participanteModel => participanteModel.condicion, new { Style = "font-size:22px" }) <a style="color:red;font-size:22px">*</a><br />
                            
                            @Html.RadioButtonFor(participanteModel => participanteModel.condicion, "Profesor(a) Interino(a)") @Html.Label("Profesor(a) Interino(a)")<br />
                            @Html.RadioButtonFor(participanteModel => participanteModel.condicion, "Profesor(a) Instructor(a)") @Html.Label("Profesor(a) Instructor(a)")<br />
                            @Html.RadioButtonFor(participanteModel => participanteModel.condicion, "Profesor(a) Adjunto(a)") @Html.Label("Profesor(a) Adjunto(a)")<br />
                            @Html.RadioButtonFor(participanteModel => participanteModel.condicion, "Profesor(a) Catedrático(a)") @Html.Label("Profesor(a) Catedrático(a)")<br />
                            @Html.RadioButtonFor(participanteModel => participanteModel.condicion, "Profesor(a) Invitado(a)") @Html.Label("Profesor(a) Invitado(a)")<br />
                            @Html.RadioButtonFor(participanteModel => participanteModel.condicion, "Profesor(a) Asociado(a)") @Html.Label("Profesor(a) Asociado(a)")<br />
                            @Html.RadioButtonFor(participanteModel => participanteModel.condicion, "Otro") @Html.Label("Otro")<br />
                            @Html.ValidationMessageFor(participanteModel => participanteModel.condicion, "", new { @class = "text-danger" })
                            
                        </div>
                    </div>
                    <div class="row justify-content-center m-4">
                        <div class="col-auto">
                            <a href="#" class="btn btn-secondary btn-block" onclick="history.go(-1); return false;">Cancelar</a>
                        </div>
                        <div class="col-auto">
                            <input type="submit" id="guardarBtn" class="btn btn-primary btn-block" value="Guardar" />
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}

<script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.0.19/dist/sweetalert2.min.js"></script>
<script type="text/javascript">
    var areasData = null;
    var enviandoFormulario = false;
    var estadoInicial = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        area = Model?.area ?? string.Empty,
        departamento = Model?.departamento ?? string.Empty,
        unidadAcademica = Model?.unidadAcademica ?? string.Empty,
        sede = Model?.sede ?? string.Empty,
        carrera = Model?.carrera ?? string.Empty
    }));

    function limpiarMensajesValidacion() {
        $('.field-validation-error')
            .text('')
            .removeClass('field-validation-error')
            .addClass('field-validation-valid');

        $('.input-validation-error').removeClass('input-validation-error');
        ocultarPopoverGuardar();
    }

    function mostrarMensajesValidacion(fieldErrors) {
        if (!fieldErrors) {
            return;
        }

        $.each(fieldErrors, function (fieldName, mensajes) {
            if (!mensajes || mensajes.length === 0) {
                return;
            }

            var mensaje = mensajes[0];
            var $campo = $('[name="' + fieldName + '"]');
            var $mensaje = $('[data-valmsg-for="' + fieldName + '"]');

            if ($campo.length) {
                $campo.addClass('input-validation-error');
            }

            if ($mensaje.length) {
                $mensaje
                    .text(mensaje)
                    .removeClass('field-validation-valid')
                    .addClass('field-validation-error');
            }
        });
    }

    function mostrarErrorGlobal(mensaje) {
        Swal.fire({
            icon: 'error',
            title: 'Error',
            text: mensaje
        });
    }

    var guardarPopover = null;

    function escaparHtml(texto) {
        return $('<div>').text(texto).html();
    }

    function mostrarPopoverGuardar(mensaje) {
        if (guardarPopover) {
            guardarPopover.dispose();
        }
        $(document).off('click.guardarPopover');
        guardarPopover = new bootstrap.Popover(document.getElementById('guardarBtn'), {
            title: '<i class="bi bi-exclamation-circle-fill text-danger me-1"></i> Error',
            content: '<span style="font-size:1.3em">' + escaparHtml(mensaje) + '</span>',
            placement: 'right',
            trigger: 'manual',
            html: true,
            allowList: Object.assign({}, bootstrap.Popover.Default.allowList, {
                span: ['style']
            })
        });
        var scrollX = window.pageXOffset;
        var scrollY = window.pageYOffset;
        guardarPopover.show();
        window.scrollTo(scrollX, scrollY);
        $(document).on('click.guardarPopover', function (e) {
            var $popover = $('.popover');
            if (!$popover.is(e.target) && $popover.has(e.target).length === 0 &&
                !$('#guardarBtn').is(e.target)) {
                ocultarPopoverGuardar();
            }
        });
    }

    function ocultarPopoverGuardar() {
        $(document).off('click.guardarPopover');
        if (guardarPopover) {
            guardarPopover.hide();
        }
    }

    function resetDepartamentos() {
        $('#departamentoDropdown').empty().append('<option value="">Seleccione un departamento...</option>');
    }

    function resetSecciones() {
        $('#seccionDropdown').empty().append('<option value="">Seleccione una unidad académica...</option>');
    }

    function resetCarreras() {
        $('#carreraDropdown').empty().append('<option value="">Seleccione una carrera...</option>');
    }

    function actualizarAreasExtraDisponibles() {
        var areaPrincipal = $('#areaDropdown').val();

        $('.area-extra-checkbox').each(function () {
            var esAreaPrincipal = $(this).val() === areaPrincipal;
            $(this).prop('disabled', esAreaPrincipal);

            if (esAreaPrincipal) {
                $(this).prop('checked', false);
            }
        });
    }

    function cargarDepartamentos(areaName, departamentoSeleccionado) {
        resetDepartamentos();
        resetSecciones();
        resetCarreras();

        if (!areaName || !areasData || !areasData.departamentosByArea || !areasData.departamentosByArea[areaName]) {
            return;
        }

        var departamentos = areasData.departamentosByArea[areaName];
        $.each(departamentos, function (index, value) {
            $('#departamentoDropdown').append('<option value="' + value + '">' + value + '</option>');
        });

        if (departamentoSeleccionado) {
            $('#departamentoDropdown').val(departamentoSeleccionado);
        }
    }

    function cargarSecciones(areaName, departamentoName, seccionSeleccionada) {
        resetSecciones();
        resetCarreras();

        if (!areaName || !departamentoName || !areasData || !areasData.seccionesByDepartamento) {
            return;
        }

        var key = areaName + '|' + departamentoName;
        var secciones = areasData.seccionesByDepartamento[key];

        if (!secciones) {
            return;
        }

        $.each(secciones, function (index, value) {
            $('#seccionDropdown').append('<option value="' + value + '">' + value + '</option>');
        });

        if (seccionSeleccionada) {
            $('#seccionDropdown').val(seccionSeleccionada);
        }
    }

    function setCarreras(carreras, carreraSeleccionada) {
        resetCarreras();

        if (!carreras || carreras.length === 0) {
            $('#carreraDropdown').append('<option value="">No hay carreras disponibles para esta combinación</option>');
            return;
        }

        $.each(carreras, function (index, value) {
            $('#carreraDropdown').append('<option value="' + value + '">' + value + '</option>');
        });

        if (carreraSeleccionada) {
            $('#carreraDropdown').val(carreraSeleccionada);
        }
    }

    function actualizarCarreras(carreraSeleccionada) {
        var area = $('#areaDropdown').val();
        var departamento = $('#departamentoDropdown').val();
        var seccion = $('#seccionDropdown').val();
        var sede = $('#sedeDropdown').val();

        resetCarreras();

        if (!area || !departamento || !seccion || !sede) {
            return $.Deferred().resolve().promise();
        }

        if (areasData &&
            areasData.carrerasBySeccionAndSede &&
            areasData.carrerasBySeccionAndSede[seccion] &&
            areasData.carrerasBySeccionAndSede[seccion][sede]) {

            setCarreras(areasData.carrerasBySeccionAndSede[seccion][sede], carreraSeleccionada);
            return $.Deferred().resolve().promise();
        }

        return $.ajax({
            url: '/Participante/GetCarrerasBySeccionAndSede',
            type: 'GET',
            data: {
                areaName: area,
                departamentoName: departamento,
                unidadAcademica: seccion,
                sede: sede
            },
            dataType: 'json',
            success: function (carreras) {
                if (!areasData.carrerasBySeccionAndSede) {
                    areasData.carrerasBySeccionAndSede = {};
                }

                if (!areasData.carrerasBySeccionAndSede[seccion]) {
                    areasData.carrerasBySeccionAndSede[seccion] = {};
                }

                areasData.carrerasBySeccionAndSede[seccion][sede] = carreras || [];
                setCarreras(carreras, carreraSeleccionada);
            },
            error: function () {
                mostrarErrorGlobal('Error al cargar las carreras.');
            }
        });
    }

    function rehidratarFormularioInicial() {
        if (!estadoInicial.area) {
            actualizarAreasExtraDisponibles();
            return;
        }

        $('#areaDropdown').val(estadoInicial.area);
        cargarDepartamentos(estadoInicial.area, estadoInicial.departamento);
        cargarSecciones(estadoInicial.area, estadoInicial.departamento, estadoInicial.unidadAcademica);

        if (estadoInicial.sede) {
            $('#sedeDropdown').val(estadoInicial.sede);
        }

        actualizarCarreras(estadoInicial.carrera);
        actualizarAreasExtraDisponibles();
    }

    $(document).ready(function () {
        var $form = $('#participanteCreateForm');
        var $submitButton = $form.find('input[type="submit"]');
        var submitLabel = $submitButton.val();

        $('#areaDropdown, #departamentoDropdown').prop('disabled', true);

        $.ajax({
            url: '/Participante/GetAllAreasData',
            type: 'GET',
            cache: true,
            dataType: 'json',
            success: function (data) {
                areasData = data || {};
                $('#areaDropdown, #departamentoDropdown').prop('disabled', false);
                rehidratarFormularioInicial();
            },
            error: function (xhr, status, error) {
                $('#areaDropdown, #departamentoDropdown').prop('disabled', false);
                mostrarErrorGlobal('Error al cargar la información del formulario: ' + error);
            }
        });

        $('#areaDropdown').on('change', function () {
            var areaName = $(this).val();
            cargarDepartamentos(areaName, null);
            actualizarAreasExtraDisponibles();
        });

        $('#departamentoDropdown').on('change', function () {
            var areaName = $('#areaDropdown').val();
            var departamentoName = $(this).val();
            cargarSecciones(areaName, departamentoName, null);
        });

        $('#seccionDropdown, #sedeDropdown').on('change', function () {
            actualizarCarreras(null);
        });

        $form.on('submit', function (event) {
            event.preventDefault();

            if (enviandoFormulario) {
                return;
            }

            enviandoFormulario = true;
            limpiarMensajesValidacion();
            $submitButton.prop('disabled', true).val('Guardando...');

            $.ajax({
                url: $form.attr('action'),
                type: 'POST',
                data: $form.serialize(),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                success: function (response) {
                    if (response && response.success && response.redirectUrl) {
                        window.location.href = response.redirectUrl;
                        return;
                    }

                    var tieneFieldErrors = response && response.fieldErrors && Object.keys(response.fieldErrors).length > 0;
                    var tieneGlobalErrors = response && response.globalErrors && response.globalErrors.length > 0;

                    if (tieneFieldErrors) {
                        mostrarMensajesValidacion(response.fieldErrors);
                        mostrarPopoverGuardar('Por favor, revise los campos marcados en rojo.');
                    } else if (tieneGlobalErrors) {
                        mostrarPopoverGuardar(response.globalErrors.join(' '));
                    }
                },
                error: function (xhr) {
                    var response = xhr.responseJSON || {};
                    var tieneFieldErrors = response.fieldErrors && Object.keys(response.fieldErrors).length > 0;
                    var tieneGlobalErrors = response.globalErrors && response.globalErrors.length > 0;

                    if (tieneFieldErrors) {
                        mostrarMensajesValidacion(response.fieldErrors);
                        mostrarPopoverGuardar('Por favor, revise los campos marcados en rojo.');
                    } else if (tieneGlobalErrors) {
                        mostrarPopoverGuardar(response.globalErrors.join(' '));
                    } else {
                        mostrarPopoverGuardar(response.message || 'Ocurrió un error inesperado.');
                    }
                },
                complete: function () {
                    enviandoFormulario = false;
                    $submitButton.prop('disabled', false).val(submitLabel);
                }
            });
        });
    });
</script>