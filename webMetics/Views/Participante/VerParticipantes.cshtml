@using webMetics.Controllers
@{
    ViewBag.Title = "Participantes";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
}

@if (ViewBag.Id != "" && ViewBag.Role == 1)
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" href="@Url.Action("ListaGruposDisponibles", "Grupo")">
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>
        }

        <h1>@ViewBag.Title</h1>
        <hr />

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-dark alert-dismissible fade show mb-4" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @ViewBag.SuccessMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive" style="padding-bottom: 220px;">

            <div style="display: flex; align-items: flex-start; gap: 15px; margin-bottom: 20px;">
                <div style="flex: 1;">
                    @using (Html.BeginForm("SubirArchivoExcelParticipantes", "Participante", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        <small class="text-secondary" style="display: block; margin-bottom: 8px;">Subir lista de participantes</small>
                        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
                            <input type="file" class="form-control" name="file" id="file" accept=".xls,.xlsx" style="font-size: 12px; flex: 1; min-width: 200px;" required>
                            <input class="btn btn-secondary" type="submit" value="Subir" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">
                        </div>
                    }
                </div>

                <div style="flex-shrink: 0;">
                    <small class="text-secondary" style="display: block; margin-bottom: 8px;">Exportar datos:</small>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <a href="@Url.Action("ExportarParticipantesPDF", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">PDF</a>
                        <a href="@Url.Action("ExportarParticipantesExcel", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Excel 1</a>
                        <a href="@Url.Action("ExportarParticipantesExcel2", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Excel 2</a>
                        <a href="@Url.Action("ExportarParticipantesWord", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Word</a>
                    </div>
                </div>
            </div>

            <div class="bg-light p-3 rounded d-flex" style="gap: 10px; margin-bottom: 20px;">
                <h4><i class="bi bi-exclamation-circle-fill me-2 p-0 text-secondary" style="font-size: 16px; line-height: 1; flex-shrink: 0;"></i></h4>
                <small class="text-muted" style="flex: 1;">
                    Subir un archivo en formato <strong>XLS</strong> o <strong>XLSX</strong> con las siguientes columnas: <strong>Unidad Académica, Nombre, Primer Apellido, Segundo Apellido, Correo Institucional, Horas Aprobadas</strong>
                    <br />
                    <a href="@Url.Action("DescargarPlantillaSubirParticipantes", "Participante")" class="btn btn-small btn-outline-secondary mt-2" style="font-size: 12px; padding: 4px 8px;">Descargar plantilla</a>
                </small>
            </div>



            @if (ViewBag.ListaParticipantes == null)
            {
                <h5 class="text-center">No hay personas inscritas en módulos.</h5>
            }
            else
            {
                <div class="table-card">
                    <div class="table-card-header">
                        <span class="table-card-title">Participantes</span>
                        <span class="table-card-desc">Listado de participantes registrados en el sistema</span>
                    </div>

                    <div class="table-toolbar">
                        <div class="table-toolbar-group">
                            <div class="table-pagesize">
                                <label for="pageSize">Mostrar</label>
                                <select id="pageSize">
                                    <option selected>5</option>
                                    <option>10</option>
                                    <option>25</option>
                                    <option>50</option>
                                </select>
                                <label for="pageSize">registros</label>
                            </div>

                            <form asp-action="BuscarParticipantes" asp-controller="Participante" method="get" class="table-search">
                                <input type="text" name="searchTerm" class="form-control" placeholder="Buscar participante" value="@Context.Request.Query["searchTerm"]" />
                                <button class="btn" type="submit"><i class="bi bi-search"></i></button>
                            </form>
                        </div>

                        <div>
                            @Html.ActionLink("  Agregar Participante", "FormularioParticipante", "Participante", new { }, new { @class = "btn btn-primary bi bi-person-plus btn-table-sm" })
                        </div>
                    </div>

                    <div class="table-scroll">
                        <table id="tblCustomers" class="data-table" style="min-width: 800px;">
                            <thead>
                                <tr>
                                    <th scope="col" class="text-center" style="width: 4%;"></th>
                                    <th scope="col" style="width: 14%;">Unidad Académica</th>
                                    <th scope="col" style="width: 24%;">Nombre Completo</th>
                                    <th scope="col" style="width: 23%;">Correo Institucional</th>
                                    <th scope="col" class="text-center" style="width: 10%;">Hrs. Inscritas</th>
                                    <th scope="col" class="text-center" style="width: 10%;">Hrs. Aprobadas</th>
                                    <th scope="col" class="text-center" style="width: 15%;">Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var participante in ViewBag.ListaParticipantes)
                                {
                                    var gruposInscritos = participante.gruposInscritos;
                                    var nombreCompleto = participante.nombre;
                                    nombreCompleto += " " + participante.primerApellido;
                                    if (participante.segundoApellido != "-")
                                    {
                                        nombreCompleto += " " + participante.segundoApellido;
                                    }
                                    <tr>
                                        <td class="text-center">
                                            @if (participante.horasAprobadas >= 30)
                                            {
                                                if (participante.correoNotificacionEnviado != 0)
                                                {
                                                    <i class="bi bi-bell" style="color: #198754;" title="Notificación enviada"></i>
                                                }
                                                else
                                                {
                                                    <a href="@Url.Action("NotificarLimiteHoras", "Participante", new { idParticipante = participante.idParticipante })" class="text-success bi bi-bell-fill" title="Notificar límite de horas"></a>
                                                }
                                            }
                                        </td>
                                        <td>@participante.unidadAcademica</td>
                                        <td>@nombreCompleto</td>
                                        <td>@participante.correo</td>
                                        <td class="text-center">
                                            <span>@participante.horasMatriculadas</span>
                                        </td>
                                        <td class="text-center">
                                            <span>@participante.horasAprobadas</span>
                                        </td>
                                        <td class="text-center">
                                            <div style="display: inline-block;">
                                                <button type="button" id="dropdownMenu_@participante.idParticipante" class="action-menu-btn" onclick="toggleActionMenu('@participante.idParticipante', event)" title="Acciones">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <div id="menu_@participante.idParticipante" class="action-menu">
                                                    <a href="@Url.Action("VerDatosParticipante", "Participante", new { idParticipante = participante.idParticipante })">
                                                        <i class="bi bi-eye" style="color: #0090D8;"></i> Ver detalles
                                                    </a>
                                                    <a href="@Url.Action("EditarParticipante", "Participante", new { idParticipante = participante.idParticipante })">
                                                        <i class="bi bi-pencil-square" style="color: #0090D8;"></i> Editar
                                                    </a>
                                                    <a href="@Url.Action("CambiarCredencialesUsuario", "Usuario", new { idUsuario = participante.idParticipante, nombreCompleto = nombreCompleto })">
                                                        <i class="bi bi-fingerprint" style="color: #0090D8;"></i> Credenciales
                                                    </a>
                                                    <a href="@Url.Action("CambiarContrasenaAdmin", "Usuario", new { idUsuario = participante.idParticipante, nombreCompleto = nombreCompleto })">
                                                        <i class="bi bi-key" style="color: #0090D8;"></i> Cambiar contraseña
                                                    </a>
                                                    <div class="action-menu-divider"></div>
                                                    <a href="#" class="delete-option" onclick="openDeleteModal('@participante.idParticipante'); return false;">
                                                        <i class="bi bi-trash"></i> Eliminar
                                                    </a>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div id="tblPaginacion" class="table-pagination"></div>
                </div>
            }
        </div>
    </div>

    <div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Eliminar participante</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro de que desea eliminar este participante?

                    @using (Html.BeginForm("EliminarParticipante", "Participante"))
                    {
                        @Html.AntiForgeryToken()

                        <div class="modal-footer">
                            <input type="hidden" id="idParticipante" name="idParticipante">
                            <input type="submit" class="btn btn-danger" value="Aceptar" onclick="" />
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}

<script type="text/javascript">
    function closeActionMenus() {
        document.querySelectorAll('[id^="menu_"]').forEach(function(menu) {
            menu.classList.remove('is-open');
            menu.style.left = '';
            menu.style.top = '';
        });
    }

    function positionActionMenu(menu, button) {
        var buttonRect = button.getBoundingClientRect();
        var margin = 8;
        var gap = 6;

        menu.style.visibility = 'hidden';
        menu.classList.add('is-open');

        var menuRect = menu.getBoundingClientRect();
        var left = buttonRect.right - menuRect.width;
        var top = buttonRect.bottom + gap;

        if (left < margin) {
            left = margin;
        }

        if (left + menuRect.width > window.innerWidth - margin) {
            left = window.innerWidth - menuRect.width - margin;
        }

        if (top + menuRect.height > window.innerHeight - margin) {
            top = buttonRect.top - menuRect.height - gap;
        }

        if (top < margin) {
            top = margin;
        }

        menu.style.left = left + 'px';
        menu.style.top = top + 'px';
        menu.style.visibility = 'visible';
    }

    // Menú de acciones personalizado
    function toggleActionMenu(participanteId, event) {
        if (event) {
            event.stopPropagation();
        }

        var menu = document.getElementById('menu_' + participanteId);
        var button = document.getElementById('dropdownMenu_' + participanteId);
        var wasOpen = menu.classList.contains('is-open');

        closeActionMenus();

        if (!wasOpen) {
            positionActionMenu(menu, button);
        }
    }

    // Cerrar menú al hacer clic fuera
    document.addEventListener('click', function(event) {
        if (!event.target.closest('[id^="menu_"]') && !event.target.closest('[id^="dropdownMenu_"]')) {
            closeActionMenus();
        }
    });

    document.addEventListener('scroll', closeActionMenus, true);
    window.addEventListener('resize', closeActionMenus);

    // Función para abrir modal de eliminación
    function openDeleteModal(participanteId) {
        document.getElementById("idParticipante").value = participanteId;
        var deleteModal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        deleteModal.show();
    }

    // Función heredada para mantener compatibilidad
    function actualizarModalEliminar(idParticipante) {
        openDeleteModal(idParticipante);
    }

    MeticsTable.init({
        tableId: 'tblCustomers',
        pageSizeId: 'pageSize',
        paginationId: 'tblPaginacion',
        searching: false
    });
</script>
