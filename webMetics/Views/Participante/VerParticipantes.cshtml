@using webMetics.Controllers
@using System.Text.Json
@{
    ViewBag.Title = "Participantes";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
}

@if (ViewBag.Id != "" && ViewBag.Role == 1)
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" href="@Url.Action("ListaGruposDisponibles", "Grupo")">
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>
        }

        <h1>@ViewBag.Title</h1>
        <hr />

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-dark alert-dismissible fade show mb-4" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @ViewBag.SuccessMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div style="padding-bottom: 220px;">

            <div style="display: flex; align-items: flex-start; gap: 15px; margin-bottom: 20px;">
                <div style="flex: 1;">
                    @using (Html.BeginForm("SubirArchivoExcelParticipantes", "Participante", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        <small class="text-secondary" style="display: block; margin-bottom: 8px;">Subir lista de participantes</small>
                        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
                            <input type="file" class="form-control" name="file" id="file" accept=".xls,.xlsx" style="font-size: 12px; flex: 1; min-width: 200px;" required>
                            <input class="btn btn-secondary" type="submit" value="Subir" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">
                        </div>
                    }
                </div>

                <div style="flex-shrink: 0;">
                    <small class="text-secondary" style="display: block; margin-bottom: 8px;">Exportar datos:</small>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <a href="@Url.Action("ExportarParticipantesPDF", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">PDF</a>
                        <a href="@Url.Action("ExportarParticipantesExcel", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Excel 1</a>
                        <a href="@Url.Action("ExportarParticipantesExcel2", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Excel 2</a>
                        <a href="@Url.Action("ExportarParticipantesWord", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Word</a>
                    </div>
                </div>
            </div>

            <div class="bg-light p-3 rounded d-flex" style="gap: 10px; margin-bottom: 20px;">
                <h4><i class="bi bi-exclamation-circle-fill me-2 p-0 text-secondary" style="font-size: 16px; line-height: 1; flex-shrink: 0;"></i></h4>
                <small class="text-muted" style="flex: 1;">
                    Subir un archivo en formato <strong>XLS</strong> o <strong>XLSX</strong> con las siguientes columnas: <strong>Unidad Académica, Nombre, Primer Apellido, Segundo Apellido, Correo Institucional, Horas Aprobadas</strong>
                    <br />
                    <a href="@Url.Action("DescargarPlantillaSubirParticipantes", "Participante")" class="btn btn-small btn-outline-secondary mt-2" style="font-size: 12px; padding: 4px 8px;">Descargar plantilla</a>
                </small>
            </div>



            <div class="table-card">
                <div class="table-card-header">
                    <span class="table-card-title">Participantes</span>
                    <span class="table-card-desc">Listado de participantes registrados en el sistema</span>
                </div>

                <div class="table-toolbar">
                    <div class="table-toolbar-group">
                        <div class="table-pagesize">
                            <label for="participantePageSize">Mostrar</label>
                            <select id="participantePageSize">
                                <option>5</option>
                                <option>10</option>
                                <option>25</option>
                                <option selected>50</option>
                            </select>
                            <label for="participantePageSize">registros</label>
                        </div>

                        <form asp-action="VerParticipantes" asp-controller="Participante" method="get" class="table-search">
                            <input type="text" name="searchTerm" class="form-control" placeholder="Buscar participante" value="@Context.Request.Query["searchTerm"]" />
                            <button class="btn" type="submit"><i class="bi bi-search"></i></button>
                        </form>
                    </div>

                    <div>
                        @Html.ActionLink("  Agregar Participante", "FormularioParticipante", "Participante", new { }, new { @class = "btn btn-primary bi bi-person-plus btn-table-sm" })
                    </div>
                </div>

                <div class="table-scroll table-scroll--fit">
                    <table id="participanteTblCustomers" class="data-table">
                        <thead>
                            <tr>
                                <th scope="col" class="text-center" style="width: 4%;"></th>
                                <th scope="col" style="width: 14%;">Unidad Académica</th>
                                <th scope="col" style="width: 24%;">Nombre Completo</th>
                                <th scope="col" style="width: 23%;">Correo Institucional</th>
                                <th scope="col" class="text-center" style="width: 10%;">Hrs. Inscritas</th>
                                <th scope="col" class="text-center" style="width: 10%;">Hrs. Aprobadas</th>
                                <th scope="col" class="text-center" style="width: 15%;">Acciones</th>
                            </tr>
                        </thead>

                        <tbody></tbody>
                    </table>
                </div>

                <div id="participanteTblPaginacion" class="table-pagination"></div>
            </div>
        </div>
    </div>

    <form method="post" asp-controller="Participante" asp-action="NotificarLimiteHoras" id="formNotificarLimiteHoras" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" id="notificarIdParticipante" name="idParticipante" />
        <input type="hidden" name="searchTerm" value="@Context.Request.Query["searchTerm"]" />
    </form>

    <div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Eliminar participante</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro de que desea eliminar este participante?

                    @using (Html.BeginForm("EliminarParticipante", "Participante"))
                    {
                        @Html.AntiForgeryToken()

                        <div class="modal-footer">
                            <input type="hidden" id="idParticipante" name="idParticipante">
                            <input type="submit" class="btn btn-danger" value="Aceptar" onclick="" />
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}

<script type="text/javascript">
    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, character => ({
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;'
        })[character]);
    }

    function participantFullName(participant) {
        return [participant.nombre, participant.primerApellido, participant.segundoApellido]
            .filter(value => value && value !== '-')
            .join(' ');
    }

    function closeActionMenus() {
        document.querySelectorAll('.action-menu.is-open').forEach(function(menu) {
            menu.classList.remove('is-open');
            menu.style.left = '';
            menu.style.top = '';
            menu.style.visibility = '';
        });
    }

    function positionActionMenu(menu, button) {
        var buttonRect = button.getBoundingClientRect();
        var margin = 8;
        var gap = 6;

        menu.style.visibility = 'hidden';
        menu.classList.add('is-open');

        var menuRect = menu.getBoundingClientRect();
        var left = buttonRect.right - menuRect.width;
        var top = buttonRect.bottom + gap;

        if (left < margin) {
            left = margin;
        }

        if (left + menuRect.width > window.innerWidth - margin) {
            left = window.innerWidth - menuRect.width - margin;
        }

        if (top + menuRect.height > window.innerHeight - margin) {
            top = buttonRect.top - menuRect.height - gap;
        }

        if (top < margin) {
            top = margin;
        }

        menu.style.left = left + 'px';
        menu.style.top = top + 'px';
        menu.style.visibility = 'visible';
    }

    function toggleActionMenu(button, event) {
        event.stopPropagation();
        var menu = button.parentElement.querySelector('.action-menu');
        var wasOpen = menu.classList.contains('is-open');

        closeActionMenus();

        if (!wasOpen) {
            positionActionMenu(menu, button);
        }
    }

    document.addEventListener('click', function(event) {
        if (!event.target.closest('.action-menu') && !event.target.closest('.js-action-menu')) {
            closeActionMenus();
        }
    });

    document.addEventListener('scroll', closeActionMenus, true);
    window.addEventListener('resize', closeActionMenus);

    function openDeleteModal(participanteId) {
        document.getElementById("idParticipante").value = participanteId;
        var deleteModal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        deleteModal.show();
    }

    function actualizarModalEliminar(idParticipante) {
        openDeleteModal(idParticipante);
    }

    const initialSearchTerm = @Html.Raw(JsonSerializer.Serialize(Context.Request.Query["searchTerm"].ToString()));
    const participantDetailsUrl = '@Url.Action("VerDatosParticipante", "Participante")';
    const participantEditUrl = '@Url.Action("EditarParticipante", "Participante")';
    const participantCredentialsUrl = '@Url.Action("CambiarCredencialesUsuario", "Usuario")';
    const participantPasswordUrl = '@Url.Action("CambiarContrasenaAdmin", "Usuario")';

    const participantesTable = MeticsTable.initServer({
        tableId: 'participanteTblCustomers',
        pageSizeId: 'participantePageSize',
        paginationId: 'participanteTblPaginacion',
        ajaxUrl: '@Url.Action("ObtenerParticipantesPaginados", "Participante")',
        pageLength: 50,
        initialSearch: initialSearchTerm,
        order: [[2, 'asc']],
        columns: [
            {
                data: 'correoNotificacionEnviado',
                orderable: false,
                searchable: false,
                className: 'text-center',
                render: function (data, type, row) {
                    if (type !== 'display' || row.horasAprobadas < 30) return '';

                    if (data !== 0) {
                        return '<i class="bi bi-bell" style="color: #198754;" title="Notificación enviada"></i>';
                    }

                    return '<button type="button" class="text-success bi bi-bell-fill border-0 bg-transparent p-0 js-notify-participant" ' +
                        'data-id-participante="' + escapeHtml(row.idParticipante) + '" title="Notificar límite de horas"></button>';
                }
            },
            { data: 'unidadAcademica', render: data => escapeHtml(data) },
            {
                data: null,
                render: function (data, type, row) {
                    return type === 'display' ? escapeHtml(participantFullName(row)) : participantFullName(row);
                }
            },
            { data: 'correo', render: data => escapeHtml(data) },
            { data: 'horasMatriculadas', className: 'text-center' },
            { data: 'horasAprobadas', className: 'text-center' },
            {
                data: null,
                orderable: false,
                searchable: false,
                className: 'text-center',
                render: function (data, type, row) {
                    if (type !== 'display') return '';

                    const participantId = encodeURIComponent(row.idParticipante);
                    const fullName = participantFullName(row);
                    const encodedName = encodeURIComponent(fullName);
                    const detailsUrl = participantDetailsUrl + '?idParticipante=' + participantId;
                    const editUrl = participantEditUrl + '?idParticipante=' + participantId;
                    const credentialsUrl = participantCredentialsUrl + '?idUsuario=' + participantId + '&nombreCompleto=' + encodedName;
                    const passwordUrl = participantPasswordUrl + '?idUsuario=' + participantId + '&nombreCompleto=' + encodedName;

                    return '<div style="display: inline-block;">' +
                        '<button type="button" class="action-menu-btn js-action-menu" title="Acciones">' +
                            '<i class="bi bi-three-dots-vertical"></i>' +
                        '</button>' +
                        '<div class="action-menu">' +
                            '<a href="' + escapeHtml(detailsUrl) + '"><i class="bi bi-eye" style="color: #0090D8;"></i> Ver detalles</a>' +
                            '<a href="' + escapeHtml(editUrl) + '"><i class="bi bi-pencil-square" style="color: #0090D8;"></i> Editar</a>' +
                            '<a href="' + escapeHtml(credentialsUrl) + '"><i class="bi bi-fingerprint" style="color: #0090D8;"></i> Credenciales</a>' +
                            '<a href="' + escapeHtml(passwordUrl) + '"><i class="bi bi-key" style="color: #0090D8;"></i> Cambiar contraseña</a>' +
                            '<div class="action-menu-divider"></div>' +
                            '<a href="#" class="delete-option js-delete-participant" data-id-participante="' + escapeHtml(row.idParticipante) + '">' +
                                '<i class="bi bi-trash"></i> Eliminar' +
                            '</a>' +
                        '</div>' +
                    '</div>';
                }
            }
        ],
        onDraw: closeActionMenus
    });

    document.getElementById('participanteTblCustomers').addEventListener('click', function (event) {
        const menuButton = event.target.closest('.js-action-menu');
        if (menuButton) {
            toggleActionMenu(menuButton, event);
            return;
        }

        const deleteLink = event.target.closest('.js-delete-participant');
        if (deleteLink) {
            event.preventDefault();
            closeActionMenus();
            openDeleteModal(deleteLink.dataset.idParticipante);
            return;
        }

        const notificationButton = event.target.closest('.js-notify-participant');
        if (notificationButton) {
            document.getElementById('notificarIdParticipante').value = notificationButton.dataset.idParticipante;
            document.getElementById('formNotificarLimiteHoras').requestSubmit();
        }
    });
</script>
