@using webMetics.Controllers
@using webMetics.Controllers
@{
    ViewBag.Title = "Participantes";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
}

<style>
    /* Estilos para la tabla de participantes - Opción C */
    .action-menu-btn {
        background: none;
        border: 1px solid #CCCCCC;
        cursor: pointer;
        padding: 5px 9px;
        color: #204C6F;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        border-radius: 2px;
        min-height: 30px;
        font-size: 14px;
        transition: background-color 0.2s ease;
    }

    .action-menu-btn:hover {
        background-color: #F5F5F5;
    }

    .action-menu {
        position: absolute;
        right: 0;
        top: 35px;
        background: white;
        border: 1px solid #CCCCCC;
        z-index: 100;
        min-width: 180px;
        box-shadow: 2px 4px 10px rgba(0,0,0,0.14);
        border-radius: 2px;
        display: none;
    }

    .action-menu a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 14px;
        font-size: 12px;
        color: #333;
        cursor: pointer;
        text-decoration: none;
        border: none;
        background: none;
        width: 100%;
        text-align: left;
        transition: background-color 0.2s ease;
    }

    .action-menu a:hover {
        background-color: #F5F5F5;
    }

    .action-menu a.delete-option {
        color: #C0392B;
    }

    .table-card {
        background: white;
        border: 2px solid #41ADE7;
        border-radius: 4px;
        margin-top: 20px;
    }

    .table-card-header {
        background: #E3F3FB;
        border-bottom: 1px solid #CCCCCC;
        padding: 11px 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .table-card-header-title {
        font-weight: bold;
        font-size: 14px;
        color: #204C6F;
    }

    .table-card-header-desc {
        font-size: 12px;
        color: #555;
    }

    .table-controls {
        padding: 14px 14px 10px 14px;
        background: white;
        border-bottom: 1px solid #ECECEC;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .table-row-striped:nth-child(even) {
        background-color: #F9F9F9;
    }

    /* Estilos para paginación de DataTable */
    .dataTables_wrapper {
        background: transparent;
    }

    .dataTables_wrapper .dataTables_top {
        background: white;
        width: 100%;
        padding: 0;
        margin: 0;
        border: none;
    }

    .dataTables_wrapper .dataTables_bottom {
        background: white;
        width: 100%;
        padding: 0;
        margin: 0;
        border-top: 1px solid #ECECEC;
    }

    .dataTables_paginate {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 4px;
        padding: 13px;
        margin: 0;
        background: white;
    }

    .dataTables_paginate .paginate_button {
        background: white;
        border: 1px solid #CCCCCC;
        padding: 5px 12px;
        font-size: 12px;
        cursor: pointer;
        color: #333;
        font-family: Arial;
        border-radius: 2px;
        margin: 0 2px;
        display: inline-block;
    }

    .dataTables_paginate .paginate_button:hover {
        background: #F5F5F5;
        border-color: #CCCCCC;
    }

    .dataTables_paginate .paginate_button.current {
        background: #204C6F;
        color: white;
        border-color: #204C6F;
    }

    .dataTables_paginate .paginate_button.current:hover {
        background: #204C6F;
        color: white;
        border-color: #204C6F;
    }

    .dataTables_paginate .paginate_button.disabled {
        opacity: 0.5;
        cursor: not-allowed;
        background: white;
        color: #999;
    }

    .dataTables_paginate .paginate_button.disabled:hover {
        background: white;
        color: #999;
        border-color: #CCCCCC;
    }

    .paginacion {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 4px;
        padding: 13px;
        border-top: 1px solid #ECECEC;
    }

    .paginacion .paginate_button {
        background: white;
        border: 1px solid #CCCCCC;
        padding: 5px 12px;
        font-size: 12px;
        cursor: pointer;
        color: #333;
        font-family: Arial;
        border-radius: 2px;
        margin: 0 2px;
    }

    .paginacion .paginate_button:hover {
        background: #F5F5F5;
        border-color: #CCCCCC;
    }

    .paginacion .paginate_button.current {
        background: #204C6F;
        color: white;
        border-color: #204C6F;
    }

    .paginacion .paginate_button.current:hover {
        background: #204C6F;
        color: white;
        border-color: #204C6F;
    }

    .paginacion .paginate_button.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

</style>

@if (ViewBag.Id != "" && ViewBag.Role == 1)
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" href="@Url.Action("ListaGruposDisponibles", "Grupo")">
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>
        }

        <h1>@ViewBag.Title</h1>
        <hr />

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-dark alert-dismissible fade show mb-4" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @ViewBag.SuccessMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive" style="padding-bottom: 220px;">

            <div style="display: flex; align-items: flex-start; gap: 15px; margin-bottom: 20px;">
                <div style="flex: 1;">
                    @using (Html.BeginForm("SubirArchivoExcelParticipantes", "Participante", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        <small class="text-secondary" style="display: block; margin-bottom: 8px;">Subir lista de participantes</small>
                        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
                            <input type="file" class="form-control" name="file" id="file" accept=".xls,.xlsx" style="font-size: 12px; flex: 1; min-width: 200px;" required>
                            <input class="btn btn-secondary" type="submit" value="Subir" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">
                        </div>
                    }
                </div>

                <div style="flex-shrink: 0;">
                    <small class="text-secondary" style="display: block; margin-bottom: 8px;">Exportar datos:</small>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <a href="@Url.Action("ExportarParticipantesPDF", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">PDF</a>
                        <a href="@Url.Action("ExportarParticipantesExcel", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Excel 1</a>
                        <a href="@Url.Action("ExportarParticipantesExcel2", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Excel 2</a>
                        <a href="@Url.Action("ExportarParticipantesWord", "Participante", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Word</a>
                    </div>
                </div>
            </div>

            <div class="bg-light p-3 rounded d-flex" style="gap: 10px; margin-bottom: 20px;">
                <h4><i class="bi bi-exclamation-circle-fill me-2 p-0 text-secondary" style="font-size: 16px; line-height: 1; flex-shrink: 0;"></i></h4>
                <small class="text-muted" style="flex: 1;">
                    Subir un archivo en formato <strong>XLS</strong> o <strong>XLSX</strong> con las siguientes columnas: <strong>Unidad Académica, Nombre, Primer Apellido, Segundo Apellido, Correo Institucional, Horas Aprobadas</strong>
                    <br />
                    <a href="@Url.Action("DescargarPlantillaSubirParticipantes", "Participante")" class="btn btn-small btn-outline-secondary mt-2" style="font-size: 12px; padding: 4px 8px;">Descargar plantilla</a>
                </small>
            </div>



            @if (ViewBag.ListaParticipantes == null)
            {
                <h5 class="text-center">No hay personas inscritas en módulos.</h5>
            }
            else
            {
                <div style="background: white; border: 2px solid #41ADE7; border-radius: 4px; margin-top: 20px;">
                    <!-- Encabezado de tarjeta -->
                    <div style="background: #E3F3FB; border-bottom: 1px solid #CCCCCC; padding: 11px 15px; display: flex; align-items: center; gap: 10px;">
                        <span style="font-weight: bold; font-size: 14px; color: #204C6F;">Participantes</span>
                        <span style="font-size: 12px; color: #555;">Listado de participantes registrados en el sistema</span>
                    </div>

                    <!-- Controles: Mostrar registros, búsqueda y crear -->
                    <div style="padding: 14px 14px 10px 14px; background: white; border-bottom: 1px solid #ECECEC; display: flex; align-items: center; gap: 15px; flex-wrap: wrap; justify-content: space-between;">
                        <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                            <div style="display: flex; align-items: center; gap: 6px;">
                                <label for="pageSize" style="font-size: 12px; color: #333; white-space: nowrap;">Mostrar</label>
                                <select id="pageSize" style="padding: 4px 6px; border: 1px solid #BFBFBF; background: white; font-size: 12px; border-radius: 2px;">
                                    <option selected>5</option>
                                    <option>10</option>
                                    <option>25</option>
                                    <option>50</option>
                                </select>
                                <label for="pageSize" style="font-size: 12px; color: #333; white-space: nowrap;">registros</label>
                            </div>

                            <div style="flex: 1; max-width: 400px;">
                                <form asp-action="BuscarParticipantes" asp-controller="Participante" method="get" style="display: flex; gap: 5px;">
                                    <input type="text" name="searchTerm" class="form-control" placeholder="Buscar participante" value="@Context.Request.Query["searchTerm"]" style="font-size: 12px; padding: 4px 8px; border: 1px solid #BFBFBF; border-radius: 2px;" />
                                    <button class="btn btn-sm" type="submit" style="background: white; border: 1px solid #BFBFBF; color: #333; font-size: 12px; padding: 4px 10px; border-radius: 2px;">
                                        <i class="bi bi-search"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div style="flex-shrink: 0;">
                            @Html.ActionLink("  Agregar Participante", "FormularioParticipante", "Participante", new { }, new { @class = "btn btn-primary bi bi-person-plus", style = "font-size: 12px; padding: 4px 12px;" })
                        </div>
                    </div>

                    <div style="overflow-x: auto; overflow-y: auto; max-height: 70vh; width: 100%; background: white;">
                        <table id="tblCustomers" style="border-collapse: collapse; font-size: 12px; width: 100%; background: white; margin: 0; min-width: 800px;">
                            <thead>
                                <tr>
                                    <th scope="col" style="background: #ECECEC; border: 1px solid #CCCCCC; padding: 9px 9px; font-weight: bold; white-space: nowrap; color: #333; text-align: left; width: 15%;">Unidad Académica</th>
                                    <th scope="col" style="background: #ECECEC; border: 1px solid #CCCCCC; padding: 9px 9px; font-weight: bold; white-space: nowrap; color: #333; text-align: left; width: 25%;">Nombre Completo</th>
                                    <th scope="col" style="background: #ECECEC; border: 1px solid #CCCCCC; padding: 9px 9px; font-weight: bold; white-space: nowrap; color: #333; text-align: left; width: 25%;">Correo Institucional</th>
                                    <th scope="col" style="background: #ECECEC; border: 1px solid #CCCCCC; padding: 9px 9px; font-weight: bold; white-space: nowrap; color: #333; text-align: center; width: 10%;">Hrs. Inscritas</th>
                                    <th scope="col" style="background: #ECECEC; border: 1px solid #CCCCCC; padding: 9px 9px; font-weight: bold; white-space: nowrap; color: #333; text-align: center; width: 10%;">Hrs. Aprobadas</th>
                                    <th scope="col" style="background: #ECECEC; border: 1px solid #CCCCCC; padding: 9px 9px; font-weight: bold; white-space: nowrap; color: #333; text-align: center; width: 15%;">Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var participante in ViewBag.ListaParticipantes)
                                {
                                    var gruposInscritos = participante.gruposInscritos;
                                    var nombreCompleto = participante.nombre;
                                    nombreCompleto += " " + participante.primerApellido;
                                    if (participante.segundoApellido != "-")
                                    {
                                        nombreCompleto += " " + participante.segundoApellido;
                                    }
                                    <tr style="background: white;">
                                        <td style="border: 1px solid #CCCCCC; padding: 8px 9px; vertical-align: middle;">@participante.unidadAcademica</td>
                                        <td style="border: 1px solid #CCCCCC; padding: 8px 9px; vertical-align: middle;">@nombreCompleto</td>
                                        <td style="border: 1px solid #CCCCCC; padding: 8px 9px; vertical-align: middle;">@participante.correo</td>
                                        <td style="border: 1px solid #CCCCCC; padding: 8px 9px; vertical-align: middle; text-align: center;">
                                            <span>@participante.horasMatriculadas</span>
                                        </td>
                                        <td style="border: 1px solid #CCCCCC; padding: 8px 9px; vertical-align: middle; text-align: center;">
                                            <span>@participante.horasAprobadas</span>
                                        </td>
                                        <td style="border: 1px solid #CCCCCC; padding: 8px 9px; vertical-align: middle; text-align: center;">
                                            <div style="display: inline-block; position: relative;">
                                                <button type="button" id="dropdownMenu_@participante.idParticipante" style="background: none; border: 1px solid #CCCCCC; cursor: pointer; padding: 5px 9px; color: #204C6F; line-height: 1; display: inline-flex; align-items: center; border-radius: 2px; min-height: 30px; font-size: 14px;" onclick="toggleActionMenu('@participante.idParticipante')" title="Acciones">
                                                    <i class="bi bi-three-dots-vertical" style="width: 16px; height: 16px;"></i>
                                                </button>
                                                <div id="menu_@participante.idParticipante" style="position: absolute; right: 0; top: 35px; background: white; border: 1px solid #CCCCCC; z-index: 100; min-width: 180px; box-shadow: 2px 4px 10px rgba(0,0,0,0.14); display: none; border-radius: 2px;">
                                                    <a href="@Url.Action("VerDatosParticipante", "Participante", new { idParticipante = participante.idParticipante })" style="display: flex; align-items: center; gap: 10px; padding: 9px 14px; font-size: 12px; color: #333; cursor: pointer; text-decoration: none; border: none; background: none; width: 100%; text-align: left;">
                                                        <i class="bi bi-eye" style="width: 14px; height: 14px; color: #0090D8;"></i> Ver detalles
                                                    </a>
                                                    <a href="@Url.Action("EditarParticipante", "Participante", new { idParticipante = participante.idParticipante })" style="display: flex; align-items: center; gap: 10px; padding: 9px 14px; font-size: 12px; color: #333; cursor: pointer; text-decoration: none; border: none; background: none; width: 100%; text-align: left;">
                                                        <i class="bi bi-pencil-square" style="width: 14px; height: 14px; color: #0090D8;"></i> Editar
                                                    </a>
                                                    <a href="@Url.Action("CambiarCredencialesUsuario", "Usuario", new { idUsuario = participante.idParticipante, nombreCompleto = nombreCompleto })" style="display: flex; align-items: center; gap: 10px; padding: 9px 14px; font-size: 12px; color: #333; cursor: pointer; text-decoration: none; border: none; background: none; width: 100%; text-align: left;">
                                                        <i class="bi bi-fingerprint" style="width: 14px; height: 14px; color: #0090D8;"></i> Credenciales
                                                    </a>
                                                    <a href="@Url.Action("CambiarContrasenaAdmin", "Usuario", new { idUsuario = participante.idParticipante, nombreCompleto = nombreCompleto })" style="display: flex; align-items: center; gap: 10px; padding: 9px 14px; font-size: 12px; color: #333; cursor: pointer; text-decoration: none; border: none; background: none; width: 100%; text-align: left;">
                                                        <i class="bi bi-key" style="width: 14px; height: 14px; color: #0090D8;"></i> Cambiar contraseña
                                                    </a>
                                                    <div style="border: none; border-top: 1px solid #ECECEC; margin: 3px 0;"></div>
                                                    <a href="#" onclick="openDeleteModal('@participante.idParticipante'); return false;" style="display: flex; align-items: center; gap: 10px; padding: 9px 14px; font-size: 12px; color: #C0392B; cursor: pointer; text-decoration: none; border: none; background: none; width: 100%; text-align: left;">
                                                        <i class="bi bi-trash" style="width: 14px; height: 14px;"></i> Eliminar
                                                    </a>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div id="tblPaginacion" style="display: flex; justify-content: center; align-items: center; gap: 4px; padding: 13px; border-top: 1px solid #ECECEC; background: white;"></div>
                </div>
            }
        </div>
    </div>

    <div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Eliminar participante</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro de que desea eliminar este participante?

                    @using (Html.BeginForm("EliminarParticipante", "Participante"))
                    {
                        @Html.AntiForgeryToken()

                        <div class="modal-footer">
                            <input type="hidden" id="idParticipante" name="idParticipante">
                            <input type="submit" class="btn btn-danger" value="Aceptar" onclick="" />
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}

<script type="text/javascript">
    // Menú de acciones personalizado
    function toggleActionMenu(participanteId) {
        var menu = document.getElementById('menu_' + participanteId);
        var allMenus = document.querySelectorAll('[id^="menu_"]');

        allMenus.forEach(function(m) {
            if (m.id !== 'menu_' + participanteId) {
                m.style.display = 'none';
            }
        });

        if (menu.style.display === 'none' || menu.style.display === '') {
            menu.style.display = 'block';
        } else {
            menu.style.display = 'none';
        }
    }

    // Cerrar menú al hacer clic fuera
    document.addEventListener('click', function(event) {
        if (!event.target.closest('[id^="menu_"]') && !event.target.closest('[id^="dropdownMenu_"]')) {
            document.querySelectorAll('[id^="menu_"]').forEach(function(menu) {
                menu.style.display = 'none';
            });
        }
    });

    // Función para abrir modal de eliminación
    function openDeleteModal(participanteId) {
        document.getElementById("idParticipante").value = participanteId;
        var deleteModal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        deleteModal.show();
    }

    // Función heredada para mantener compatibilidad
    function actualizarModalEliminar(idParticipante) {
        openDeleteModal(idParticipante);
    }

    // Control de paginación básico
    function goToPage(page) {
        // Esta función puede ser mejorada si se requiere
        console.log('Go to page: ' + page);
    }
</script>

<link rel="stylesheet" href="https://cdn.datatables.net/1.12.1/css/jquery.dataTables.min.css">
<script src="https://code.jquery.com/jquery-3.5.1.js"></script>
<script src="https://cdn.datatables.net/1.12.1/js/jquery.dataTables.min.js"></script>

<script>
    var table = new DataTable('#tblCustomers', {
        language: {
            url: '//cdn.datatables.net/plug-ins/2.1.7/i18n/es-ES.json',
        },
        searching: false,
        paging: true,
        pageLength: 5,
        lengthMenu: [5, 10, 25, 50],
        info: false,
        lengthChange: false,
        dom: 't',
        pagingType: "simple_numbers",
        drawCallback: function () {
            if (!window.bootstrap?.Tooltip) return;
            $(this.api().rows({ page: 'current' }).nodes()).find('[data-bs-toggle="tooltip"]').each(function () {
                var existing = bootstrap.Tooltip.getInstance(this);
                if (!existing) {
                    new bootstrap.Tooltip(this);
                }
            });
        }
    });

    // Colocar paginación manualmente en su contenedor
    table.on('draw', function() {
        var paginationHtml = '';
        var pageCount = Math.ceil(table.page.info().recordsTotal / table.page.len());
        var currentPage = table.page() + 1;

        // Botón anterior
        if (currentPage > 1) {
            paginationHtml += '<a href="#" class="paginate_button" onclick="table.page(' + (currentPage - 2) + ').draw(false); return false;" style="background: white; border: 1px solid #CCCCCC; padding: 5px 12px; font-size: 12px; cursor: pointer; color: #333; font-family: Arial; border-radius: 2px; margin: 0 2px; display: inline-block; text-decoration: none;">&laquo;</a>';
        }

        // Números de página
        for (var i = 1; i <= pageCount; i++) {
            if (i === currentPage) {
                paginationHtml += '<span class="paginate_button current" style="background: #204C6F; color: white; border: 1px solid #204C6F; padding: 5px 12px; font-size: 12px; font-family: Arial; border-radius: 2px; margin: 0 2px; display: inline-block;">' + i + '</span>';
            } else {
                paginationHtml += '<a href="#" class="paginate_button" onclick="table.page(' + (i - 1) + ').draw(false); return false;" style="background: white; border: 1px solid #CCCCCC; padding: 5px 12px; font-size: 12px; cursor: pointer; color: #333; font-family: Arial; border-radius: 2px; margin: 0 2px; display: inline-block; text-decoration: none;">' + i + '</a>';
            }
        }

        // Botón siguiente
        if (currentPage < pageCount) {
            paginationHtml += '<a href="#" class="paginate_button" onclick="table.page(' + currentPage + ').draw(false); return false;" style="background: white; border: 1px solid #CCCCCC; padding: 5px 12px; font-size: 12px; cursor: pointer; color: #333; font-family: Arial; border-radius: 2px; margin: 0 2px; display: inline-block; text-decoration: none;">&raquo;</a>';
        }

        document.getElementById('tblPaginacion').innerHTML = paginationHtml;
    });

    // Conectar el selector de "Mostrar X registros" con DataTable
    document.getElementById('pageSize').addEventListener('change', function() {
        var value = parseInt(this.value);
        table.page.len(value).draw();
    });

    document.addEventListener('DOMContentLoaded', function () {
        if (!window.bootstrap?.Tooltip) return;
        $('#tblCustomers [data-bs-toggle="tooltip"]').each(function () {
            if (!bootstrap.Tooltip.getInstance(this)) {
                new bootstrap.Tooltip(this);
            }
        });
    });
