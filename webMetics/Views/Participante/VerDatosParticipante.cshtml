@model webMetics.Models.ParticipanteModel
@{
    ViewBag.Title = "Módulos del Participante";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
    var volverController = "Inscripcion";
    var volverAction = "VerInscripciones";
    object volverRouteValues = new { };
    var volverTexto = "Regresar";

    if (ViewBag.IdGrupo != null)
    {
        volverController = "Participante";
        volverAction = "ListaParticipantes";
        volverRouteValues = new { idGrupo = ViewBag.IdGrupo };
        volverTexto = "Regresar a Módulo";
    }
    else if (!string.IsNullOrWhiteSpace(urlReferrer) &&
             urlReferrer.Contains("/Participante/VerParticipantes", StringComparison.OrdinalIgnoreCase))
    {
        volverController = "Participante";
        volverAction = "VerParticipantes";
    }
}

<style>
    .medalla-list-container {
    max-height: 300px; /* Increased height */
    overflow-y: auto;
    border: 0px solid #ccc;
    padding: 10px;
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    gap: 10px; /* Added gap for better spacing */
    }

    .medalla-item {
    display: flex; /* Use flexbox for vertical layout */
    flex-direction: column; /* Stack image and checkbox vertically */
    align-items: center; /* Center items horizontally */
    text-align: center;
    width: 200px;
    }

    .medalla-image {
    max-width: 200px; /* Increased image size */
    max-height: 200px;
    margin-bottom: 5px;
    }

    /* La tarjeta y su encabezado usan las clases compartidas
       .table-card / .table-card-header (site.css). */
    .participante-detalle-wrapper {
        overflow-x: auto;
        width: 100%;
        background: white;
    }

    .participante-detalle-table {
        border-collapse: collapse;
        font-size: 12px;
        width: 100%;
        min-width: 1100px;
        background: white;
        margin: 0;
    }

    .participante-detalle-table th {
        background: #ECECEC;
        border: 1px solid #CCCCCC;
        padding: 9px;
        font-weight: bold;
        white-space: nowrap;
        color: #333;
        text-align: left;
        vertical-align: middle;
    }

    .participante-detalle-table td {
        border: 1px solid #CCCCCC;
        padding: 8px 9px;
        vertical-align: top;
    }

    .participante-detalle-table .detalle-label {
        width: 16%;
        background: #F9F9F9;
        color: #204C6F;
        font-weight: bold;
        white-space: nowrap;
    }

    .participante-detalle-table .detalle-value {
        width: 34%;
    }

    .detalle-empty {
        color: #777;
    }

    .detalle-badge {
        display: inline-block;
        background: #E3F3FB;
        border: 1px solid #41ADE7;
        border-radius: 2px;
        color: #204C6F;
        font-size: 12px;
        margin: 2px 4px 2px 0;
        padding: 2px 6px;
    }

    .modulos-detalle-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 18px;
    }

    .modulos-detalle-card {
        background: white;
        border: 1px solid #CCCCCC;
        border-radius: 4px;
        overflow: hidden;
    }

    .modulo-detalle-toggle {
        align-items: center;
        background: #F9F9F9;
        border: 0;
        border-bottom: 1px solid #CCCCCC;
        color: #204C6F;
        display: flex;
        gap: 10px;
        justify-content: space-between;
        padding: 11px 14px;
        text-align: left;
        width: 100%;
    }

    .modulo-detalle-toggle:hover {
        background: #E3F3FB;
    }

    .modulo-detalle-title {
        align-items: center;
        display: flex;
        gap: 8px;
        min-width: 0;
    }

    .modulo-detalle-name {
        color: #204C6F;
        font-size: 13px;
        font-weight: bold;
        line-height: 1.35;
    }

    .modulo-detalle-status {
        background: white;
        border: 1px solid #CCCCCC;
        border-radius: 2px;
        color: #333;
        flex-shrink: 0;
        font-size: 12px;
        padding: 3px 7px;
    }

    .modulo-detalle-wrapper {
        overflow-x: auto;
        width: 100%;
    }

    .modulo-detalle-table {
        background: white;
        border-collapse: collapse;
        font-size: 12px;
        margin: 0;
        min-width: 980px;
        width: 100%;
    }

    .modulo-detalle-table th {
        background: #ECECEC;
        border: 1px solid #CCCCCC;
        color: #333;
        font-weight: bold;
        padding: 9px;
        text-align: left;
        vertical-align: middle;
        white-space: nowrap;
    }

    .modulo-detalle-table td {
        border: 1px solid #CCCCCC;
        padding: 8px 9px;
        vertical-align: middle;
    }

    .modulo-detalle-table .form-control {
        font-size: 12px;
        max-width: 125px;
    }
</style>

@if (ViewBag.Role == 1 || ViewBag.Role == 2)
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" href="@Url.Action(volverAction, volverController, volverRouteValues)">
                    <i class="bi bi-arrow-left"> </i>
                </a>
            </div>
        }

        <h1>@ViewBag.Title</h1>
        <hr />

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-dark alert-dismissible fade show mb-4" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @ViewBag.SuccessMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive">
            @if (ViewBag.Participante == null)
            {
                <h5 class="text-center">Los datos de este participante no están disponibles.</h5>
            }
            else
            {
                <!-- Selector de medallas (admin) -->
                @if (ViewBag.Role == 1)
                {
                    <br />
                    <div class="card">
                        <div class="card-header" id="medallasHeader">
                            <h3 class="mb-0">
                                <button class="bi bi-chevron-down btn text-muted" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMedallas" aria-expanded="true" aria-controls="collapseMedallas">
                                    Asignar Medallas
                                </button>
                            </h3>
                        </div>

                        <div id="collapseMedallas" class="collapse show" aria-labelledby="medallasHeader">
                            <div class="card-body">
                                <form method="post" asp-controller="Participante" asp-action="AsignarMedallas">
                                    <input type="hidden" name="idParticipante" value="@ViewBag.Participante.idParticipante" />

                                    <div class="d-flex justify-content-between mb-3">
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="medallaSearch" onkeyup="filterMedals()" placeholder="Ingrese el nombre de la medalla">
                                            <span class="input-group-text">
                                                <i class="bi bi-search"></i>
                                            </span>
                                        </div>
                                        <div class="d-flex justify-content-end ms-3">
                                            <button type="submit" class="btn btn-secondary">Asignar</button>
                                        </div>
                                    </div>

                                    <div class="mb-3" style="max-height: 200px; overflow-y: auto; border: 1px solid #ccc; padding: 5px; border-radius: 5px;">
                                        <div id="medallaList" class="medalla-list-container">
                                            @if (ViewBag.TodasMedallas != null)
                                            {
                                                @foreach (var medalla in ViewBag.TodasMedallas)
                                                {
                                                    <div class="d-flex flex-column">
                                                        <div class="medalla-item">
                                                            <img src="~/images/medallas/@medalla" alt="@medalla" class="medalla-image" />
                                                        </div>
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" name="selectedMedallas" value="@medalla" id="medalla-@medalla">
                                                            <label class="form-check-label" for="medalla-@medalla">
                                                                @medalla
                                                            </label>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <p>No hay medallas disponibles.</p>
                                            }
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }

                <!-- Medallas -->
                @if (ViewBag.Medallas != null)
                {
                    <br />
                    <h3 class="">Medallas</h3>

                    <div class="d-flex justify-content-start mt-4">
                        @foreach (string nombreMedalla in ViewBag.Medallas)
                        {
                            <div class="card me-2 h-100" style="width: 300px; height: 300px;">
                                @if (ViewBag.Role == 1)
                                {
                                    <div class="card-header text-muted">
                                        <div style="float:right">
                                            <i class="bi bi-trash3 text-danger" type="button" data-bs-toggle="modal" data-bs-target="#modalEliminar" onclick="actualizarModalEliminar('@nombreMedalla')"></i>
                                        </div>
                                    </div>
                                }
                                @{
                                    var medalPath = Directory.EnumerateFiles("wwwroot/images/medallas", nombreMedalla).FirstOrDefault();
                                }
                                @if (medalPath != null)
                                {
                                    var normalizedMedalPath = medalPath.Replace('\\', '/');
                                    var relativeMedalPath = normalizedMedalPath.Replace("wwwroot/", "/", StringComparison.OrdinalIgnoreCase);

                                    <div class="card-body">
                                        <img class="card-img" src="@relativeMedalPath" style="height: 250px; width: 250px;" />
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                <br />

                var nombreCompleto = ViewBag.Participante.nombre;
                nombreCompleto += " " + ViewBag.Participante.primerApellido;

                if (ViewBag.Participante.segundoApellido != "-")
                {
                    nombreCompleto += " " + ViewBag.Participante.segundoApellido;
                }

                var participante = ViewBag.Participante;
                var areasParticipante = participante.areasExtra as List<string> ?? new List<string>();
                string ValueOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
                string NotificationStatus(int value) => value != 0 ? "Enviada" : "No enviada";

                <div class="table-card">
                    <div class="table-card-header">
                        <span class="table-card-title">Datos del participante</span>
                        <span class="table-card-desc">Información completa registrada en el sistema</span>
                    </div>

                    <div class="participante-detalle-wrapper">
                        <table class="participante-detalle-table">
                            <thead>
                                <tr>
                                    <th colspan="4">Información personal y académica</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="detalle-label">Nombre completo</td>
                                    <td class="detalle-value">@nombreCompleto</td>
                                    <td class="detalle-label">Correo institucional</td>
                                    <td class="detalle-value">@ValueOrDash(participante.correo)</td>
                                </tr>
                                <tr>
                                    <td class="detalle-label">Correo alternativo</td>
                                    <td class="detalle-value">@ValueOrDash(participante.correoAlternativo)</td>
                                    <td class="detalle-label">Grado académico</td>
                                    <td class="detalle-value">@ValueOrDash(participante.gradoAcademico)</td>
                                </tr>
                                <tr>
                                    <td class="detalle-label">Tipo de identificación</td>
                                    <td class="detalle-value">@ValueOrDash(participante.tipoIdentificacion)</td>
                                    <td class="detalle-label">Número de identificación</td>
                                    <td class="detalle-value">@ValueOrDash(participante.numeroIdentificacion)</td>
                                </tr>
                                <tr>
                                    <td class="detalle-label">Área principal</td>
                                    <td class="detalle-value">@ValueOrDash(participante.area)</td>
                                    <td class="detalle-label">Áreas extra</td>
                                    <td class="detalle-value">
                                        @if (!areasParticipante.Any())
                                        {
                                            <span class="detalle-empty">Ninguna</span>
                                        }
                                        else
                                        {
                                            foreach (var area in areasParticipante)
                                            {
                                                <span class="detalle-badge">@area</span>
                                            }
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="detalle-label">Facultad o departamento</td>
                                    <td class="detalle-value">@ValueOrDash(participante.departamento)</td>
                                    <td class="detalle-label">Unidad académica</td>
                                    <td class="detalle-value">@ValueOrDash(participante.unidadAcademica)</td>
                                </tr>
                                <tr>
                                    <td class="detalle-label">Sede y recinto</td>
                                    <td class="detalle-value">@ValueOrDash(participante.sede)</td>
                                    <td class="detalle-label">Carrera</td>
                                    <td class="detalle-value">@ValueOrDash(participante.carrera)</td>
                                </tr>
                                <tr>
                                    <td class="detalle-label">Tipo de participante</td>
                                    <td class="detalle-value">@ValueOrDash(participante.tipoParticipante)</td>
                                    <td class="detalle-label">Condición</td>
                                    <td class="detalle-value">@ValueOrDash(participante.condicion)</td>
                                </tr>
                                <tr>
                                    <td class="detalle-label">Teléfono</td>
                                    <td class="detalle-value">@ValueOrDash(participante.telefono)</td>
                                    <td class="detalle-label">Identificador</td>
                                    <td class="detalle-value">@ValueOrDash(participante.idParticipante)</td>
                                </tr>
                                <tr>
                                    <td class="detalle-label">Total horas inscritas</td>
                                    <td class="detalle-value">@participante.horasMatriculadas</td>
                                    <td class="detalle-label">Total horas aprobadas</td>
                                    <td class="detalle-value">@participante.horasAprobadas</td>
                                </tr>
                                <tr>
                                    <td class="detalle-label">Notificación de límite de horas</td>
                                    <td class="detalle-value">@NotificationStatus(participante.correoNotificacionEnviado)</td>
                                    <td class="detalle-label">Módulos inscritos</td>
                                    <td class="detalle-value">
                                        @if (ViewBag.Inscripciones == null)
                                        {
                                            <span class="detalle-empty">Ninguno</span>
                                        }
                                        else
                                        {
                                            foreach (var inscripcion in ViewBag.Inscripciones)
                                            {
                                                <div>@inscripcion.nombreGrupo (Grupo @inscripcion.numeroGrupo)</div>
                                            }
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                @if (ViewBag.Inscripciones != null)
                {
                    <div class="modulos-detalle-list">
                        @foreach (var inscripcion in ViewBag.Inscripciones)
                        {
                            <div class="modulos-detalle-card">
                                <button class="modulo-detalle-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#detalle-@inscripcion.idInscripcion" aria-expanded="false" aria-controls="detalle-@inscripcion.idInscripcion">
                                    <span class="modulo-detalle-title">
                                        <i class="bi bi-chevron-down"></i>
                                        <span class="modulo-detalle-name">@inscripcion.nombreGrupo (Grupo @inscripcion.numeroGrupo)</span>
                                    </span>
                                    <span class="modulo-detalle-status">@inscripcion.estado</span>
                                </button>

                                <div id="detalle-@inscripcion.idInscripcion" class="collapse">
                                    <div class="modulo-detalle-wrapper">
                                        <table class="modulo-detalle-table">
                                            <thead>
                                                <tr>
                                                    <th scope="col" style="width:20%;">Nombre Completo</th>
                                                    <th scope="col" style="width:20%;">Módulo</th>
                                                    <th scope="col" style="width:7.5%;">Estado</th>
                                                    <th class="text-center" scope="col" style="width: 7.5%;">Horas<br>Inscritas</th>
                                                    <th class="text-center" scope="col" style="width: 7.5%;">Horas<br>Aprobadas</th>
                                                    <th class="text-center" scope="col" style="width: 15%;">Aprobar<br>Horas</th>
                                                    <th class="text-center" scope="col" style="width: 7.5%;">Calificación</th>
                                                    <th class="text-center" scope="col" style="width: 15%;">Editar<br>Calificación</th>
                                                    <th class="text-center" scope="col" style="width: 3.33%;"></th>
                                                </tr>
                                            </thead>

                                            <tbody class="align-middle">
                                                <tr>
                                                    <td>@nombreCompleto</td>
                                                    <td>@inscripcion.nombreGrupo (Grupo @inscripcion.numeroGrupo)</td>
                                                    <td>@inscripcion.estado</td>
                                                    <td class="text-center">@((inscripcion.horasMatriculadas ?? 0))</td>
                                                    <td class="text-center">@((inscripcion.horasAprobadas ?? 0))</td>
                                                    @using (Html.BeginForm("SubirHorasAprobadasYCalificacion", "Calificaciones", new { idGrupo = inscripcion.idGrupo, idParticipante = ViewBag.Participante.idParticipante }, FormMethod.Post))
                                                    {
                                                        <td class="text-center">
                                                            <input type="number" min="0" class="form-control mx-auto" name="horasAprobadas">
                                                        </td>
                                                        <td class="text-center">@((inscripcion.calificacion ?? 0))</td>
                                                        <td class="text-center">
                                                            <input type="number" min="0" , max="100" class="form-control mx-auto" name="calificacion" id="calificacion">
                                                        </td>
                                                        <td class="text-center">
                                                            <button type="submit" class="btn btn-secondary bi bi-check-lg" title="Guardar"></button>
                                                        </td>
                                                    }
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            <hr />
            <div class="d-flex my-4 justify-content-center">
                <a href="@Url.Action(volverAction, volverController, volverRouteValues)" class="btn btn-secondary btn-block">@volverTexto</a>
            </div>
        </div>

        <div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel">Eliminar medalla</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        ¿Está seguro de que desea eliminar esta medalla?
                        <br />
                        @using (Html.BeginForm("EliminarMedallaParticipante", "Medallas"))
                        {
                            <div class="modal-footer">
                                <input type="hidden" id="idParticipante" name="idParticipante" value="@ViewBag.Participante.idParticipante">
                                <input type="hidden" id="nombreMedalla" name="nombreMedalla">
                                <input type="submit" class="btn btn-danger" value="Aceptar" />
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}
<script>
        function filterMedals() {
        var input, filter, medallaList, medallas, i, txtValue;
        input = document.getElementById("medallaSearch");
        filter = input.value.toUpperCase();
        medallaList = document.getElementById("medallaList");
        medallas = medallaList.getElementsByClassName("medalla-item");

        for (i = 0; i < medallas.length; i++) {
            txtValue = medallas[i].textContent || medallas[i].innerText;
            if (txtValue.toUpperCase().indexOf(filter) > -1) {
                medallas[i].style.display = "";
            } else {
                medallas[i].style.display = "none";
            }
        }
    }
</script>
<script type="text/javascript">
    function actualizarModalEliminar(nombreMedalla) {
        document.getElementById("nombreMedalla").value = nombreMedalla;
    }
</script>
