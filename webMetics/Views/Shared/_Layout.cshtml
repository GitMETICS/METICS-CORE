<!DOCTYPE html>
<!--
    Aqui se encuentra el Header y Footer del sitio web que se comparte para cada vista del sitio
//-->
@using webMetics.Controllers

<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">

    <!-- jQuery se carga una sola vez en el head para que esté disponible en todas las vistas (DataTables, etc.) -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    <!-- DataTables se carga una sola vez (versión 1.13.x) para todas las vistas de listado.
         El helper compartido MeticsTable vive en site.js. -->
    <link rel="stylesheet" href="//cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css">
    <script src="//cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</head>
<body>
    <div style="background-color: #095998; height: 95px;">
        <div class="logo-container">
            <div class="d-flex justify-content-between align-items-center" style="position: relative; z-index: 0;">

                <div class="logo-link ms-4 py-2">
                    <a href="https://www.ucr.ac.cr/">
                        <img src="@Url.Content("~/images/ucr.svg")" style="height: 65px; width: auto;" alt="Logo Universidad de Costa Rica" />
                    </a>
                </div>

                <div class="d-flex justify-content-end align-items-center">
                    <div class="logo-link me-3 py-2">
                        <a href="https://vd.ucr.ac.cr/" style="display: block;">
                            <img src="@Url.Content("~/images/VD-01.png")" style="height: 56px; width: auto;" alt="Logo Vicerrectoria de Docencia" />
                        </a>
                    </div>

                    <div class="logo-link me-4 py-2">
                        <a href="https://metics.ucr.ac.cr/es/">
                            <img src="@Url.Content("~/images/METICS-01.png")" style="height: 65px; width: auto;" alt="Logo METICS" />
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>




    @{
        string navUserId = Convert.ToString(ViewBag.Id) ?? "";
        string navRoleValue = Convert.ToString(ViewBag.Role) ?? "";
        int navRole = 0;
        int.TryParse(navRoleValue, out navRole);
        string currentController = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "";
        string currentAction = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "";
        bool showNav = !string.IsNullOrEmpty(navUserId)
            && ViewBag.Title != "Formulario de Registro"
            && ViewBag.Title != "Iniciar sesión"
            && ViewBag.Title != "Recuperar Contraseña"
            && ViewBag.Title != "Completar Información - Correo Alternativo"
            && ViewBag.Title != "Completar Información - Grado Académico";
        bool isAcademicActive = currentController == "Categoria" || (currentController == "Tema" && currentAction != "CrearTema");
        bool isPeopleActive = currentController == "Participante" || (currentController == "Asesor" && currentAction != "MisModulos");
        bool isInscriptionActive = currentController == "Inscripcion";
        bool isContentActive = currentController == "Medallas"
            || (currentController == "Tema" && currentAction == "CrearTema")
            || (currentController == "Grupo" && currentAction == "CrearGrupo");
        bool isHomeActive = currentController == "Grupo" && currentAction == "ListaGruposDisponibles";
        bool isFacilitatorActive = (currentController == "Asesor" && currentAction == "MisModulos")
            || (currentController == "Grupo" && currentAction == "CrearGrupo");
        string roleLabel = navRole == 1 ? "Administrador" : navRole == 2 ? "Facilitador(a)" : "Participante";
    }

    @if (showNav)
    {
        <nav class="navbar navbar-expand-lg metics-tabs-navbar">
            <div class="container-fluid metics-tabs-container">
                <button class="navbar-toggler metics-tabs-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01" aria-controls="navbarColor01" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse metics-tabs-collapse" id="navbarColor01">
                    <div class="metics-tabs-left">
                        @if (navRole == 1)
                        {
                            <ul class="navbar-nav metics-tabs-nav">
                                <li class="nav-item dropdown metics-settings-tab">
                                    <a class="nav-link metics-icon-tab" href="#" id="settingsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Configuración" aria-label="Configuración">
                                        <i class="bi bi-gear"></i>
                                    </a>
                                    <ul class="dropdown-menu metics-tabs-menu" aria-labelledby="settingsDropdown">
                                        <li>@Html.ActionLink("Configuración del correo", "Index", "EmailSettings", new { }, new { @class = "dropdown-item" })</li>
                                        <li>@Html.ActionLink("Registro de accesos", "VerBitacoraAccesos", "Usuario", new { }, new { @class = "dropdown-item" })</li>
                                    </ul>
                                </li>

                                <li class="nav-item dropdown metics-tab @(isAcademicActive ? "active" : "")">
                                    <a class="nav-link dropdown-toggle" href="#" id="academicDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-list-ul"></i>
                                        <span>Gestión académica</span>
                                    </a>
                                    <ul class="dropdown-menu metics-tabs-menu" aria-labelledby="academicDropdown">
                                        <li>@Html.ActionLink("Niveles", "ListaCategorias", "Categoria", new { }, new { @class = "dropdown-item" })</li>
                                        <li>@Html.ActionLink("Áreas de competencia", "ListaTemas", "Tema", new { }, new { @class = "dropdown-item" })</li>
                                    </ul>
                                </li>

                                <li class="nav-item dropdown metics-tab @(isPeopleActive ? "active" : "")">
                                    <a class="nav-link dropdown-toggle" href="#" id="peopleDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-people"></i>
                                        <span>Personas</span>
                                    </a>
                                    <ul class="dropdown-menu metics-tabs-menu" aria-labelledby="peopleDropdown">
                                        <li>@Html.ActionLink("Lista de facilitadores(as)", "ListaAsesores", "Asesor", new { }, new { @class = "dropdown-item" })</li>
                                        <li>@Html.ActionLink("Lista de participantes", "VerParticipantes", "Participante", new { }, new { @class = "dropdown-item" })</li>
                                    </ul>
                                </li>

                                <li class="nav-item dropdown metics-tab @(isInscriptionActive ? "active" : "")">
                                    <a class="nav-link dropdown-toggle" href="#" id="inscriptionDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-card-checklist"></i>
                                        <span>Inscripciones</span>
                                    </a>
                                    <ul class="dropdown-menu metics-tabs-menu" aria-labelledby="inscriptionDropdown">
                                        <li>@Html.ActionLink("Lista de inscripciones", "VerInscripciones", "Inscripcion", new { }, new { @class = "dropdown-item" })</li>
                                    </ul>
                                </li>

                                <li class="nav-item dropdown metics-tab @(isContentActive ? "active" : "")">
                                    <a class="nav-link dropdown-toggle" href="#" id="contentDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-file-earmark-plus"></i>
                                        <span>Contenido</span>
                                    </a>
                                    <ul class="dropdown-menu metics-tabs-menu" aria-labelledby="contentDropdown">
                                        <li>@Html.ActionLink("Crear un área de competencia", "CrearTema", "Tema", new { }, new { @class = "dropdown-item" })</li>
                                        <li>@Html.ActionLink("Crear un módulo", "CrearGrupo", "Grupo", new { }, new { @class = "dropdown-item" })</li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>@Html.ActionLink("Medallas", "ListaMedallas", "Medallas", new { }, new { @class = "dropdown-item" })</li>
                                    </ul>
                                </li>

                                <li class="nav-item metics-tab @(isHomeActive ? "active" : "")">
                                    <a class="nav-link" asp-controller="Grupo" asp-action="ListaGruposDisponibles" title="Inicio">
                                        <i class="bi bi-house-door-fill"></i>
                                        <span>Inicio</span>
                                    </a>
                                </li>
                            </ul>
                        }
                        else if (navRole == 2)
                        {
                            <ul class="navbar-nav metics-tabs-nav">
                                <li class="nav-item dropdown metics-tab @(isFacilitatorActive ? "active" : "")">
                                    <a class="nav-link dropdown-toggle" href="#" id="facilitatorDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-person-workspace"></i>
                                        <span>Facilitador(a)</span>
                                    </a>
                                    <ul class="dropdown-menu metics-tabs-menu" aria-labelledby="facilitatorDropdown">
                                        <li>@Html.ActionLink("Mis módulos", "MisModulos", "Asesor", new { }, new { @class = "dropdown-item" })</li>
                                        <li>@Html.ActionLink("Crear un módulo", "CrearGrupo", "Grupo", new { }, new { @class = "dropdown-item" })</li>
                                    </ul>
                                </li>

                                <li class="nav-item metics-tab @(isHomeActive ? "active" : "")">
                                    <a class="nav-link" asp-controller="Grupo" asp-action="ListaGruposDisponibles" title="Inicio">
                                        <i class="bi bi-house-door-fill"></i>
                                        <span>Inicio</span>
                                    </a>
                                </li>
                            </ul>
                        }
                        else
                        {
                            <ul class="navbar-nav metics-tabs-nav">
                                <li class="nav-item metics-tab @(isHomeActive ? "active" : "")">
                                    <a class="nav-link" asp-controller="Grupo" asp-action="ListaGruposDisponibles" title="Inicio">
                                        <i class="bi bi-house-door-fill"></i>
                                        <span>Inicio</span>
                                    </a>
                                </li>
                            </ul>
                        }
                    </div>

                    <div class="metics-tabs-right">
                        @if (navRole == 1 || navRole == 2)
                        {
                            @Html.ActionLink("Crear módulo", "CrearGrupo", "Grupo", new { }, new { @class = "btn btn-secondary metics-create-module bi bi-plus-lg" })
                        }

                        <ul class="navbar-nav">
                            <li class="nav-item dropdown metics-account">
                                <a class="nav-link dropdown-toggle metics-account-link" href="#" id="accountDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                    <span>@roleLabel</span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end metics-tabs-menu" aria-labelledby="accountDropdown">
                                    <li>@Html.ActionLink("Información personal", "InformacionPersonal", "Usuario", new { }, new { @class = "dropdown-item" })</li>
                                    <li>@Html.ActionLink("Cambiar contraseña", "CambiarContrasena", "Usuario", null, new { @class = "dropdown-item" })</li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>@Html.ActionLink("Cerrar sesión", "CerrarSesion", "Usuario", new { }, new { @class = "dropdown-item metics-logout" })</li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    }
    <div class="container body-content" style="min-height: 100vh">
        @RenderBody()
    </div>

    <!-- Footer -->
    <footer class="text-center text-lg-start text-white" id="footer" style="background-color: #3e4551; bottom: 0px; width: 100%; height: 100%;">
        <div class="container p-4 pb-5">
            <section class="">
                <div class="row h-100">
                    <div class="col-md-4">
                        <!-- Información de los contactos  -->
                        @{await Html.RenderPartialAsync("~/Views/Shared/Info.cshtml"); }
                    </div>                   
                </div>
            </section>
        </div>
        <div class="text-center p-1">
            <p>&copy; @DateTime.Now.Year METICS</p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.9.2/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
