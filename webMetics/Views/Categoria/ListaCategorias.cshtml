@using webMetics.Controllers
@{
    ViewBag.Title = "Niveles";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
}

@if (ViewBag.Id != "" && ViewBag.Role == 1)
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" href="@Url.Action("ListaGruposDisponibles", "Grupo")">
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>
        }

        <h1>@ViewBag.Title</h1>
        <hr />

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-dark alert-dismissible fade show mb-4" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @ViewBag.SuccessMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (ViewBag.Categorias == null)
        {
            <h5 class="text-center mb-4">No hay categorías.</h5>
            <div class="text-center">
                @Html.ActionLink("  Crear Nivel", "CrearCategoria", "Categoria", new { }, new { @class = "btn btn-primary bi bi-plus-lg" })
            </div>
        }
        else
        {
            <div class="table-card">
                <div class="table-card-header">
                    <span class="table-card-title">Niveles</span>
                    <span class="table-card-desc">Listado de niveles registrados en el sistema</span>
                </div>

                <div class="table-toolbar">
                    <div class="table-toolbar-group">
                        <div class="table-pagesize">
                            <label for="categoriaPageSize">Mostrar</label>
                            <select id="categoriaPageSize">
                                <option selected>5</option>
                                <option>10</option>
                                <option>25</option>
                                <option>50</option>
                            </select>
                            <label for="categoriaPageSize">registros</label>
                        </div>

                        <div class="table-search">
                            <input type="text" id="categoriaBusqueda" class="form-control" placeholder="Buscar nivel" />
                            <button type="button" class="btn"><i class="bi bi-search"></i></button>
                        </div>
                    </div>

                    <div>
                        @Html.ActionLink("  Crear Nivel", "CrearCategoria", "Categoria", new { }, new { @class = "btn btn-primary bi bi-plus-lg btn-table-sm" })
                    </div>
                </div>

                <div class="table-scroll">
                    <table id="categoriaTblCustomers" class="data-table" style="min-width: 700px;">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 30%;">Nombre</th>
                                <th scope="col" style="width: 60%;">Descripción</th>
                                <th scope="col" class="text-center" style="width: 5%;">Editar</th>
                                <th scope="col" class="text-center" style="width: 5%;">Eliminar</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var categoria in ViewBag.Categorias)
                            {
                                <tr>
                                    <td>@categoria.nombre</td>
                                    <td>@categoria.descripcion</td>
                                    <td class="text-center">
                                        @Html.ActionLink("", "EditarCategoria", "Categoria", new { idCategoria = categoria.idCategoria }, new { @class = "icon-action icon-edit bi bi-pencil-square", @title = "Editar" })
                                    </td>
                                    <td class="text-center">
                                        <a href="#" onclick="actualizarModalEliminar('@categoria.idCategoria'); return false;" class="icon-action icon-delete bi bi-trash" title="Eliminar"></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div id="categoriaTblPaginacion" class="table-pagination"></div>
            </div>
        }
    </div>

    <div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Eliminar categoría</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro de que desea eliminar esta categoría?
                    <br />
                    @using (Html.BeginForm("EliminarCategoria", "Categoria"))
                    {
                        <div class="modal-footer">
                            <input type="hidden" id="idCategoria" name="idCategoria">
                            <input type="submit" class="btn btn-danger" value="Aceptar" />
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}

<script type="text/javascript">
    function actualizarModalEliminar(idCategoria) {
        document.getElementById("idCategoria").value = idCategoria;
        var deleteModal = new bootstrap.Modal(document.getElementById('modalEliminar'));
        deleteModal.show();
    }

    MeticsTable.init({
        tableId: 'categoriaTblCustomers',
        pageSizeId: 'categoriaPageSize',
        paginationId: 'categoriaTblPaginacion',
        searching: true,
        searchInputId: 'categoriaBusqueda'
    });
</script>
