@using webMetics.Controllers
@using System.Text.Json
@{
    ViewBag.Title = "Inscripciones";

    var urlReferrer = Context.Request.Headers["Referer"].FirstOrDefault();
}

@if (ViewBag.Id != "" && ViewBag.Role == 1)
{
    <div class="contenedor-caja container-fluid">
        @if (urlReferrer != null)
        {
            <div class="d-flex justify-content-start mb-3">
                <a class="text-dark fs-4" href="@Url.Action("ListaGruposDisponibles", "Grupo")">
                    <i class="bi bi-arrow-left"></i>
                </a>
            </div>
        }

        <h1>@ViewBag.Title</h1>
        <hr />

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-dark alert-dismissible fade show mb-4" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                @ViewBag.SuccessMessage
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div style="padding-bottom: 220px;">

            <div style="display: flex; align-items: flex-start; gap: 15px; margin-bottom: 20px;">
                <div style="flex: 1;">
                    @using (Html.BeginForm("SubirArchivoExcelInscripciones", "Inscripcion", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        <small class="text-secondary" style="display: block; margin-bottom: 8px;">Subir lista de inscripciones</small>
                        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
                            <input type="file" class="form-control" name="file" id="file" accept=".xls,.xlsx" style="font-size: 12px; flex: 1; min-width: 200px;" required>
                            <input class="btn btn-secondary" type="submit" value="Subir" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">
                        </div>
                    }
                </div>

                <div style="flex-shrink: 0;">
                    <small class="text-secondary" style="display: block; margin-bottom: 8px;">Exportar datos:</small>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <a href="@Url.Action("ExportarTodosParticipantesPDF", "Inscripcion", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">PDF</a>
                        <a href="@Url.Action("ExportarTodosParticipantesExcel", "Inscripcion", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Excel</a>
                        <a href="@Url.Action("ExportarTodosParticipantesWord", "Inscripcion", new { searchTerm = Context.Request.Query["searchTerm"] })" class="btn btn-outline-secondary bi bi-download" style="font-size: 12px; padding: 4px 12px; white-space: nowrap;">Word</a>
                    </div>
                </div>
            </div>

            <div class="bg-light p-3 rounded d-flex" style="gap: 10px; margin-bottom: 20px;">
                <h4><i class="bi bi-exclamation-circle-fill me-2 p-0 text-secondary" style="font-size: 16px; line-height: 1; flex-shrink: 0;"></i></h4>
                <small class="text-muted" style="flex: 1;">
                    Subir un archivo en formato <strong>XLS</strong> o <strong>XLSX</strong> con al menos las siguientes columnas: <strong>Correo Institucional, Módulo, Grupo, Horas, Estado, Horas Completadas</strong>
                    <br />
                    <a href="@Url.Action("DescargarPlantillaSubirInscripciones", "Inscripcion")" class="btn btn-small btn-outline-secondary mt-2" style="font-size: 12px; padding: 4px 8px;">Descargar plantilla</a>
                </small>
            </div>



            <!-- Sección de Asignación de Medallas -->
                <div class="mb-4">
                    <form method="post" asp-controller="Participante" asp-action="AsignarMedallaMasiva" asp-antiforgery="false" id="formAsignarMedallas">
                        @Html.AntiForgeryToken()
                        <div id="selectedParticipantsInputs"></div>
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title mb-3">
                                    <i class="bi bi-award me-2"></i>Asignación Masiva de Medallas
                                </h5>

                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="form-label"><b>Buscar Medalla:</b></label>
                                        <div class="input-group mb-3">
                                            <input type="text" class="form-control" id="medalla-search" onkeyup="filterMedals()" placeholder="Ingrese el nombre de la medalla">
                                            <span class="input-group-text">
                                                <i class="bi bi-search"></i>
                                            </span>
                                        </div>

                                        <div class="mb-3" style="max-height: 150px; overflow-y: auto; border: 1px solid #dee2e6; padding: 10px; border-radius: 8px; background-color: #f8f9fa;">
                                            @if (ViewBag.TodasLasMedallas != null)
                                            {
                                                <div id="medalla-list" class="medalla-list-container d-flex flex-column">
                                                    @foreach (var medalla in ViewBag.TodasLasMedallas)
                                                    {
                                                        <div class="medalla-item">
                                                            <img src="~/images/medallas/@medalla" alt="@medalla" class="medalla-image" style="width: 164px; height: 164px; object-fit: contain;" />
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" id="medallaSeleccionada" name="nombreMedalla" value="@medalla">
                                                                <label class="form-check-label" for="medallaSeleccionada">
                                                                    @medalla
                                                                </label>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="medalla-list-container">
                                                    <p>No hay medallas disponibles.</p>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <label class="form-label"><b>Participantes Seleccionados:</b></label>
                                            <small class="text-muted">
                                                <span id="selectedCount">0</span> seleccionados
                                            </small>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllParticipants()">
                                                <i class="bi bi-check-all me-1"></i>Seleccionar página
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearAllParticipants()">
                                                <i class="bi bi-x-circle me-1"></i>Limpiar
                                            </button>
                                            <button type="submit" class="btn btn-success" id="btnAsignarMedallas">
                                                <i class="bi bi-award me-1"></i>Asignar Medallas
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="table-card">
                    <div class="table-card-header">
                        <span class="table-card-title">Inscripciones</span>
                        <span class="table-card-desc">Listado de inscripciones registradas en el sistema</span>
                    </div>

                    <div class="table-toolbar">
                        <div class="table-toolbar-group">
                            <form id="refreshForm2" method="get" action="@Url.Action("VerInscripciones", "Inscripcion")" style="margin: 0;">
                                <button type="submit" class="icon-action icon-view" id="refreshButton2" title="Recargar datos">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </form>

                            <div class="table-pagesize">
                                <label for="inscripcionPageSize">Mostrar</label>
                                <select id="inscripcionPageSize">
                                    <option>5</option>
                                    <option>10</option>
                                    <option>25</option>
                                    <option selected>50</option>
                                </select>
                                <label for="inscripcionPageSize">registros</label>
                            </div>

                            <form asp-action="VerInscripciones" asp-controller="Inscripcion" method="get" class="table-search">
                                <input type="text" name="searchTerm" class="form-control" placeholder="Buscar inscripción" value="@Context.Request.Query["searchTerm"]" />
                                <button class="btn" type="submit"><i class="bi bi-search"></i></button>
                            </form>
                        </div>
                    </div>

                    <div class="table-scroll table-scroll--fit">
                        <table id="inscripcionTblCustomers" class="data-table">
                            <thead>
                                <tr>
                                    <th scope="col" class="text-center" style="width: 3%;">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="selectAllCheckbox" onchange="toggleAllParticipants()">
                                        </div>
                                    </th>
                                    <th scope="col" style="width: 8%;">Nombre</th>
                                    <th scope="col" style="width: 7%;">Primer Apellido</th>
                                    <th scope="col" style="width: 7%;">Segundo Apellido</th>
                                    <th scope="col" style="width: 12%;">Correo Institucional</th>
                                    <th scope="col" style="width: 15%;">Módulo</th>
                                    <th scope="col" style="width: 8%;">Estado</th>
                                    <th scope="col" class="text-center" style="width: 8%;">Horas Inscritas</th>
                                    <th scope="col" class="text-center" style="width: 8%;">Horas Aprobadas</th>
                                    <th scope="col" class="text-center" style="width: 4%;">Ver</th>
                                    <th scope="col" class="text-center" style="width: 8%;">Eliminar</th>
                                </tr>
                            </thead>

                            <tbody></tbody>
                        </table>
                    </div>

                    <div id="inscripcionTblPaginacion" class="table-pagination"></div>
                </div>
        </div>
    </div>

    <!-- Ventana emergente de eliminación -->
    <div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Eliminar inscripción</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    ¿Está seguro de que desea eliminar la inscripción de este participante?
                    <br />
                    @using (Html.BeginForm("EliminarInscripcion", "Inscripcion"))
                    {
                        @Html.AntiForgeryToken()

                        <div class="modal-footer">
                            <input type="hidden" id="nombreGrupo" name="nombreGrupo">
                            <input type="hidden" id="numeroGrupo" name="numeroGrupo">
                            <input type="hidden" id="idParticipante" name="idParticipante">

                            <input type="submit" class="btn btn-danger" value="Aceptar" />
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript para la funcionalidad de selección de participantes y filtro de medallas -->
    <script>
        const selectedParticipants = new Set();

        function escapeHtml(value) {
            return String(value ?? '').replace(/[&<>"']/g, character => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#39;'
            })[character]);
        }

        function syncSelectedParticipantInputs() {
            const container = document.getElementById('selectedParticipantsInputs');
            container.innerHTML = '';

            selectedParticipants.forEach(idParticipante => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'participantesSeleccionados';
                input.value = idParticipante;
                container.appendChild(input);
            });
        }

        function updateSelectedCount() {
            const pageCheckboxes = Array.from(document.querySelectorAll('.participant-checkbox'));
            const selectAllCheckbox = document.getElementById('selectAllCheckbox');
            document.getElementById('selectedCount').textContent = selectedParticipants.size;

            if (pageCheckboxes.length === 0) {
                selectAllCheckbox.indeterminate = false;
                selectAllCheckbox.checked = false;
                return;
            }

            const selectedOnPage = pageCheckboxes.filter(checkbox =>
                selectedParticipants.has(checkbox.dataset.participantId));

            if (selectedOnPage.length === 0) {
                selectAllCheckbox.indeterminate = false;
                selectAllCheckbox.checked = false;
            } else if (selectedOnPage.length === pageCheckboxes.length) {
                selectAllCheckbox.indeterminate = false;
                selectAllCheckbox.checked = true;
            } else {
                selectAllCheckbox.checked = false;
                selectAllCheckbox.indeterminate = true;
            }
        }

        function refreshCurrentPageSelection() {
            document.querySelectorAll('.participant-checkbox').forEach(checkbox => {
                checkbox.checked = selectedParticipants.has(checkbox.dataset.participantId);
            });
            updateSelectedCount();
        }

        function handleParticipantSelection(checkbox) {
            const idParticipante = checkbox.dataset.participantId;
            if (checkbox.checked) {
                selectedParticipants.add(idParticipante);
            } else {
                selectedParticipants.delete(idParticipante);
            }

            syncSelectedParticipantInputs();
            refreshCurrentPageSelection();
        }

        function toggleAllParticipants() {
            const selectAllCheckbox = document.getElementById('selectAllCheckbox');
            const participantCheckboxes = document.querySelectorAll('.participant-checkbox');

            participantCheckboxes.forEach(checkbox => {
                const idParticipante = checkbox.dataset.participantId;
                if (selectAllCheckbox.checked) {
                    selectedParticipants.add(idParticipante);
                } else {
                    selectedParticipants.delete(idParticipante);
                }
            });

            syncSelectedParticipantInputs();
            refreshCurrentPageSelection();
        }

        function selectAllParticipants() {
            const participantCheckboxes = document.querySelectorAll('.participant-checkbox');

            participantCheckboxes.forEach(checkbox => {
                selectedParticipants.add(checkbox.dataset.participantId);
            });

            syncSelectedParticipantInputs();
            refreshCurrentPageSelection();
        }

        function clearAllParticipants() {
            selectedParticipants.clear();
            syncSelectedParticipantInputs();
            refreshCurrentPageSelection();
        }

        // ------ Función para filtrar medallas ------
        function filterMedals() {
            const searchInput = document.getElementById('medalla-search').value.toLowerCase();
            const medalItems = document.querySelectorAll('.medalla-item');

            medalItems.forEach(item => {
                const label = item.querySelector('.form-check-label').textContent.toLowerCase();
                if (label.includes(searchInput)) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        }

        function actualizarModalEliminarInscripcion(nombreGrupo, numeroGrupo, idParticipante) {
            document.getElementById("nombreGrupo").value = nombreGrupo;
            document.getElementById("numeroGrupo").value = numeroGrupo;
            document.getElementById("idParticipante").value = idParticipante;
            var deleteModal = new bootstrap.Modal(document.getElementById('modalEliminar'));
            deleteModal.show();
        }

        function actualizarModalEliminar(nombreGrupo, numeroGrupo, idParticipante) {
            actualizarModalEliminarInscripcion(nombreGrupo, numeroGrupo, idParticipante);
        }

        const initialSearchTerm = @Html.Raw(JsonSerializer.Serialize(Context.Request.Query["searchTerm"].ToString()));
        const participantDetailsUrl = '@Url.Action("VerDatosParticipante", "Participante")';

        const inscripcionesTable = MeticsTable.initServer({
            tableId: 'inscripcionTblCustomers',
            pageSizeId: 'inscripcionPageSize',
            paginationId: 'inscripcionTblPaginacion',
            ajaxUrl: '@Url.Action("ObtenerInscripcionesPaginadas", "Inscripcion")',
            pageLength: 50,
            initialSearch: initialSearchTerm,
            order: [[1, 'asc']],
            columns: [
                {
                    data: 'idParticipante',
                    orderable: false,
                    searchable: false,
                    className: 'text-center',
                    render: function (data, type, row) {
                        if (type !== 'display') return data;
                        const participantId = escapeHtml(data);
                        return '<div class="form-check">' +
                            '<input type="checkbox" class="form-check-input participant-checkbox" ' +
                            'id="participante_' + row.idInscripcion + '" ' +
                            'data-participant-id="' + participantId + '" ' +
                            'onchange="handleParticipantSelection(this)">' +
                            '</div>';
                    }
                },
                {
                    data: 'nombre',
                    render: function (data, type, row) {
                        if (type !== 'display') return data;
                        const fullName = [row.nombre, row.primerApellido, row.segundoApellido]
                            .filter(value => value && value !== '-')
                            .join(' ');
                        return '<span class="table-desktop-only">' + escapeHtml(data) + '</span>' +
                            '<span class="table-mobile-only">' + escapeHtml(fullName) + '</span>';
                    }
                },
                { data: 'primerApellido', render: data => escapeHtml(data) },
                { data: 'segundoApellido', render: data => escapeHtml(data) },
                { data: 'correo', render: data => escapeHtml(data) },
                {
                    data: 'nombreGrupo',
                    render: function (data, type, row) {
                        if (type !== 'display') return data;
                        return escapeHtml(data) + ' (Grupo ' + escapeHtml(row.numeroGrupo) + ')';
                    }
                },
                { data: 'estado', render: data => escapeHtml(data) },
                { data: 'horasMatriculadas', className: 'text-center' },
                { data: 'horasAprobadas', className: 'text-center' },
                {
                    data: 'idParticipante',
                    orderable: false,
                    searchable: false,
                    className: 'text-center',
                    render: function (data, type) {
                        if (type !== 'display') return data;
                        const url = participantDetailsUrl + '?idParticipante=' + encodeURIComponent(data);
                        return '<a href="' + escapeHtml(url) + '" class="icon-action icon-view bi bi-search" ' +
                            'title="Ver datos del participante"></a>';
                    }
                },
                {
                    data: null,
                    orderable: false,
                    searchable: false,
                    className: 'text-center',
                    render: function (data, type, row) {
                        if (type !== 'display') return '';
                        return '<a href="#" class="icon-action icon-delete bi bi-trash js-delete-inscripcion" ' +
                            'data-nombre-grupo="' + escapeHtml(row.nombreGrupo) + '" ' +
                            'data-numero-grupo="' + row.numeroGrupo + '" ' +
                            'data-id-participante="' + escapeHtml(row.idParticipante) + '" ' +
                            'title="Eliminar inscripción"></a>';
                    }
                }
            ],
            onDraw: refreshCurrentPageSelection
        });

        document.getElementById('inscripcionTblCustomers').addEventListener('click', function (event) {
            const deleteLink = event.target.closest('.js-delete-inscripcion');
            if (!deleteLink) return;

            event.preventDefault();
            actualizarModalEliminarInscripcion(
                deleteLink.dataset.nombreGrupo,
                deleteLink.dataset.numeroGrupo,
                deleteLink.dataset.idParticipante);
        });

        document.getElementById('formAsignarMedallas').addEventListener('submit', syncSelectedParticipantInputs);
    </script>
}
else
{
    <script>
        window.location.href = '@Url.Action("CerrarSesion", "Usuario")';
    </script>
}
